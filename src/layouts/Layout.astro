---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

type SchemaType = 'WebPage' | 'CollectionPage' | 'BlogPosting';

interface BlogPostingMeta {
  headline: string;
  description: string;
  datePublished: string;
  dateModified?: string;
  keywords?: string[];
}

interface Props {
  title?: string;
  description?: string;
  schemaType?: SchemaType;
  blogPosting?: BlogPostingMeta;
  markdownAlternate?: string;
}

const {
  title,
  description = 'AI & LLM Engineering — production agentic systems on Anthropic Claude and Google Gemini, Retrieval-Augmented Generation (RAG), Model Context Protocol (MCP). Software Engineer based in Toronto with 20+ years shipping software, cloud infrastructure, and DevOps across Google Cloud and Azure.',
  schemaType = 'WebPage',
  blogPosting,
  markdownAlternate,
} = Astro.props;

const pageTitle = title
  ? `${title} | Konstantin Borovik`
  : 'Konstantin Borovik — Software Engineer | AI & LLM Engineering';

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const siteOrigin = (Astro.site ?? new URL('https://lab5.ca')).origin;

const personId = `${siteOrigin}/#person`;
const websiteId = `${siteOrigin}/#website`;

const personNode = {
  '@type': 'Person',
  '@id': personId,
  name: 'Konstantin Borovik',
  alternateName: 'K. Borovik',
  url: `${siteOrigin}/`,
  image: `${siteOrigin}/kb-headshot.jpg`,
  jobTitle: 'Software Engineer | AI & LLM Engineering',
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Toronto',
    addressRegion: 'ON',
    addressCountry: 'CA',
  },
  sameAs: [
    'https://www.linkedin.com/in/kborovik',
    'https://github.com/kborovik',
  ],
  knowsAbout: [
    'Large Language Models (LLM)',
    'Retrieval-Augmented Generation (RAG)',
    'Model Context Protocol (MCP)',
    'AI Agents',
    'AI Engineering',
    'Agentic AI Development',
    'LLM Integration',
    'Anthropic Claude',
    'Anthropic API',
    'Google Gemini',
    'Pydantic AI',
    'Prompt Engineering',
    'Claude Code',
    'Claude Skills',
    'AI-Augmented Development',
    'Python',
    'TypeScript',
    'Node.js',
    'Bash',
    'SQL',
    'FastAPI',
    'Pydantic',
    'Astro',
    'Cloudflare Workers',
    'REST APIs',
    'API Design',
    'OpenAPI',
    'Webhooks',
    'Event-Driven Architecture',
    'Microservices',
    'Distributed Systems',
    'Asynchronous Programming',
    'PostgreSQL',
    'SQLite',
    'Cloud SQL',
    'ETL',
    'Data Pipelines',
    'Structured-Extraction Pipelines',
    'Salesforce Developer',
    'Salesforce Integration',
    'Salesforce APIs',
    'Pytest',
    'Test Automation',
    'Unit Testing',
    'Test-Driven Development (TDD)',
    'Spec-Driven Development (SDD)',
    'Git',
    'Version Control',
    'Object-Oriented Programming',
    'Backend Development',
    'Full-Stack Development',
    'Software Architecture',
    'Google Cloud Platform (GCP)',
    'Cloud Run',
    'Cloud Functions',
    'BigQuery',
    'Vertex AI',
    'Cloud Composer',
    'Pub/Sub',
    'Microsoft Azure',
    'Azure App Service',
    'Azure Functions',
    'Azure Service Bus',
    'Azure Key Vault',
    'DevOps',
    'Platform Engineering',
    'DevSecOps',
    'Infrastructure as Code (IaC)',
    'Terraform',
    'Ansible',
    'Helm',
    'Docker',
    'Kubernetes',
    'Google Kubernetes Engine (GKE)',
    'Azure Kubernetes Service (AKS)',
    'Container Orchestration',
    'Continuous Integration',
    'Continuous Deployment',
    'GitHub Actions',
    'Azure DevOps',
    'Apache Airflow',
    'Workflow Orchestration',
    'Linux',
    'Shell Scripting',
    'YAML',
    'Observability',
    'OpenTelemetry',
    'Pydantic Logfire',
    'GCP Cloud Logging',
    'GCP Log Analysis',
    'Cloud Security',
    'Secrets Management',
    'Identity and Access Management (IAM)',
    'NIST 800-53',
    'PCI DSS',
  ],
  worksFor: {
    '@type': 'Organization',
    name: 'Konstantin Borovik',
    url: `${siteOrigin}/`,
  },
  potentialAction: {
    '@type': 'AskAction',
    name: 'Ask MailPilot live agent',
    description:
      'Send a question to hello@lab5.ca; live AI agent reply returns under 60 seconds.',
    target: {
      '@type': 'EntryPoint',
      urlTemplate: 'mailto:hello@lab5.ca',
      actionPlatform: [
        'http://schema.org/DesktopWebPlatform',
        'http://schema.org/MobileWebPlatform',
      ],
    },
  },
};

const websiteNode = {
  '@type': 'WebSite',
  '@id': websiteId,
  url: `${siteOrigin}/`,
  name: 'Konstantin Borovik',
  publisher: { '@id': personId },
  inLanguage: 'en-CA',
};

type JsonLdNode = Record<string, unknown>;

const pageNode: JsonLdNode = {
  '@type': schemaType,
  '@id': `${canonicalURL.href}#${schemaType.toLowerCase()}`,
  url: canonicalURL.href,
  name: pageTitle,
  description,
  isPartOf: { '@id': websiteId },
  inLanguage: 'en-CA',
};

if (schemaType === 'BlogPosting') {
  pageNode.about = { '@id': personId };
}

if (schemaType === 'BlogPosting' && blogPosting) {
  pageNode.headline = blogPosting.headline;
  pageNode.description = blogPosting.description;
  pageNode.datePublished = blogPosting.datePublished;
  if (blogPosting.dateModified) pageNode.dateModified = blogPosting.dateModified;
  if (blogPosting.keywords && blogPosting.keywords.length > 0) {
    pageNode.keywords = blogPosting.keywords;
  }
  pageNode.author = { '@id': personId };
  pageNode.image = `${siteOrigin}/og.png`;
}

const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';
const isRoot = pathname === '/';

const segmentLabel: Record<string, string> = {
  projects: 'Projects',
  mailpilot: 'MailPilot',
  blog: 'Blog',
};

let breadcrumbNode: JsonLdNode | null = null;
if (!isRoot) {
  const segments = pathname.split('/').filter(Boolean);
  const items: Array<{ name: string; item: string }> = [
    { name: 'Home', item: `${siteOrigin}/` },
  ];
  let acc = '';
  for (let i = 0; i < segments.length; i++) {
    acc += `/${segments[i]}`;
    const isLast = i === segments.length - 1;
    const name = isLast && title ? title : (segmentLabel[segments[i]] ?? segments[i]);
    items.push({ name, item: `${siteOrigin}${acc}` });
  }
  breadcrumbNode = {
    '@type': 'BreadcrumbList',
    itemListElement: items.map((it, idx) => ({
      '@type': 'ListItem',
      position: idx + 1,
      name: it.name,
      item: it.item,
    })),
  };
}

const graph: JsonLdNode[] = [personNode, websiteNode, pageNode];
if (breadcrumbNode) graph.push(breadcrumbNode);

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': graph,
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="canonical" href={canonicalURL} />
    <link rel="alternate" hreflang="en-ca" href={canonicalURL} />
    <link rel="alternate" hreflang="x-default" href={canonicalURL} />
    <link rel="alternate" type="application/rss+xml" title="lab5.ca blog" href="/rss.xml" />
    {markdownAlternate && (
      <link rel="alternate" type="text/markdown" href={markdownAlternate} />
    )}
    <meta name="generator" content={Astro.generator} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500;600;700&display=swap" rel="stylesheet" />

    <title>{pageTitle}</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="Konstantin Borovik" />
    <meta property="og:locale" content="en_CA" />

    <!-- OG Image -->
    <meta property="og:image" content="https://lab5.ca/og.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Konstantin Borovik — Software Engineer | AI & LLM Engineering" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://lab5.ca/og.png" />
    <meta name="twitter:image:alt" content="Konstantin Borovik — Software Engineer | AI & LLM Engineering" />

    <!-- JSON-LD structured data -->
    <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body class="font-mono antialiased bg-gh-canvas text-gh-fg">
    <svg aria-hidden="true" style="display:none;position:absolute;width:0;height:0">
      <defs>
        <linearGradient id="logo-m-gradient" x1="0%" y1="0%" x2="100%" y2="0%">
          <stop offset="0%"   stop-color="#1f883d" />
          <stop offset="100%" stop-color="#0969da" />
        </linearGradient>
      </defs>
    </svg>
    <Nav />
    <main>
      <slot />
    </main>
    <Footer />
    <script>
      if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.1 }
        );
        document.querySelectorAll('.animate-on-scroll').forEach((el) => observer.observe(el));
      }
    </script>
  </body>
</html>
