---
interface Props {
  size?: 'sm' | 'md' | 'lg';
  showText?: boolean;
  class?: string;
}
const { size = 'md', showText = true, class: className = '' } = Astro.props;
const sizeMap = {
  sm: { svg: 16, text: 'text-sm',  gap: 'gap-1.5' },
  md: { svg: 20, text: 'text-lg',  gap: 'gap-2'   },
  lg: { svg: 28, text: 'text-2xl', gap: 'gap-2.5' },
};
const { svg: svgSize, text: textClass, gap: gapClass } = sizeMap[size];
---
<span class={`inline-flex items-center ${gapClass} font-bold tracking-tight text-gh-fg ${className}`}>
  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
       width={svgSize} height={svgSize} aria-hidden="true"
       stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <rect x="2" y="4" width="20" height="16" rx="2" class="stroke-gh-red" />
    <path d="m22 7-8.991 5.727a2 2 0 0 1-2.009 0L2 7" class="stroke-gh-yellow" />
  </svg>
  {showText && (
    <span class={textClass}><span class="text-gh-blue">Mail</span><span class="text-gh-green">Pilot</span></span>
  )}
</span>
