---
import Layout from '../layouts/Layout.astro';

const steps = [
  {
    num: '01',
    title: 'send a product question',
    body: 'Email demo@lab5.ca with a question about the product specs in the knowledge base. Out-of-kb questions get a reply explaining how the demo works.',
  },
  {
    num: '02',
    title: 'agent searches the knowledge base',
    body: 'The agent searches product documentation stored in Google Drive, running retrieval over indexed specs to find relevant passages.',
  },
  {
    num: '03',
    title: 'you get a sourced reply',
    body: 'Within sixty seconds the agent replies with an answer grounded in the source documents. End-to-end automated: Gmail push → retrieval → llm → reply.',
  },
];

const stack = [
  {
    num: '01',
    title: 'frontend',
    body: 'Astro SSG, Tailwind CSS, Cloudflare Workers. Static generation, zero cold-start, globally distributed.',
  },
  {
    num: '02',
    title: 'backend',
    body: 'Python, serverless functions, event-driven. Triggered by Gmail push notifications via Pub/Sub. Scale-to-zero costs.',
  },
  {
    num: '03',
    title: 'ai layer',
    body: 'LLM with retrieval over Google Drive. Structured prompts guide answer format. Out-of-kb detection prevents hallucination.',
  },
];

const canAnswer = [
  'What is the permeate flow rate in GPD for the TW-12.0K-840 model, and what is the motor horsepower required at 60Hz?',
  'What is the continuous flow rate in GPM and peak flow rate in GPM for the WS36-600-2 softener?',
  'What is the maximum flow rate of the C403 UV-COM model, and what is its UV dose range?',
  'What is the permeate flow rate and active area of the FilmTec ECO-440i RO membrane?',
  'What percentage of free chlorine can KDF 55 medium remove, and what is the heavy metal removal efficiency of KDF 55, KDF 85, and KDF-C media?',
  'What is the capacity in GPD of the RO-500 Series model TW-270K-8580 installed in Nicaragua, and how many 8" TFC spiral wound membranes does this system contain?',
];

const willDecline = [
  'Which Pentair commercial reverse osmosis system would you recommend for a 300 GPM brewery feedwater application?',
  'Can you spec a Grundfos CRN dosing pump for chlorine injection at 25 GPH?',
  'Which Veolia OPUS II system handles produced water with 50,000 ppm TDS for oil and gas?',
];
---

<Layout
  title="Proof"
  description="MailPilot — a production AI agent I built end-to-end. Email it a question; the reply is evidence of the work."
>
  <!-- Header -->
  <section class="mx-auto max-w-3xl px-6 pt-16 pb-8 sm:pt-20 sm:pb-10 text-center">
    <p class="text-sm font-bold uppercase tracking-[0.2em] text-gh-blue">
      // proof of capability
    </p>
    <h1 class="mt-4 text-3xl font-bold tracking-tight text-gh-fg sm:text-4xl">
      MailPilot
    </h1>
    <p class="mx-auto mt-4 max-w-xl text-sm leading-relaxed text-gh-fg-muted sm:text-base">
      A production AI agent I built end-to-end. Reads email, retrieves from a knowledge base, replies in under sixty seconds. Evidence of the work, not a sandbox.
    </p>

    <div class="mt-10 inline-flex items-center gap-3 rounded-lg border border-gh-border bg-gh-canvas-subtle px-5 py-3 text-sm text-gh-fg">
      <span class="text-gh-fg-subtle">$</span>
      <span>mail demo@lab5.ca</span>
      <button
        id="copy-email-btn"
        aria-label="Copy email address"
        class="flex items-center gap-1.5 rounded-md border border-gh-border bg-white px-2.5 py-1 text-xs font-semibold text-gh-fg-muted transition-colors hover:text-gh-fg cursor-pointer"
      >
        <svg id="copy-icon" class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
        </svg>
        <span id="copy-label">copy</span>
      </button>
    </div>

    <p class="mt-4 text-xs text-gh-fg-subtle">
      replies in &lt;60s · no signup · real production agent
    </p>
  </section>

  <!-- How it works -->
  <section class="border-t border-gh-border py-12 sm:py-14">
    <div class="mx-auto max-w-3xl px-6">
      <p class="text-sm font-bold uppercase tracking-[0.2em] text-gh-blue">
        // how it works
      </p>
      <div class="mt-10 grid gap-10 sm:grid-cols-3 sm:gap-8">
        {steps.map(step => (
          <div class="animate-on-scroll">
            <div class="flex items-baseline gap-2 text-xs text-gh-fg-subtle">
              <span>{step.num}</span>
              <span class="h-px flex-1 bg-gh-border"></span>
            </div>
            <h3 class="mt-3 text-sm font-bold text-gh-fg">{step.title}</h3>
            <p class="mt-2 text-xs leading-relaxed text-gh-fg-muted">{step.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Knowledge base -->
  <section class="border-t border-gh-border py-12 sm:py-14">
    <div class="mx-auto max-w-3xl px-6">
      <p class="text-sm font-bold uppercase tracking-[0.2em] text-gh-blue">
        // knowledge base
      </p>
      <p class="mt-6 max-w-2xl text-sm leading-relaxed text-gh-fg-muted">
        Sample questions are based on real product specification sheets. Cross-check the agent&rsquo;s answers against the source documents.
      </p>
      <a
        href="https://drive.google.com/drive/folders/1IUuPinOopUv_YWOZyFpt2ZX8Hd8bpZat"
        target="_blank"
        rel="noopener noreferrer"
        class="mt-6 inline-flex items-center gap-2 rounded-lg border border-gh-border bg-white px-4 py-2 text-sm font-bold text-gh-fg transition-colors hover:bg-gh-canvas-subtle"
      >
        <svg class="h-4 w-4" viewBox="0 0 87.3 78" fill="currentColor">
          <path d="M6.6 66.85l3.85 6.65c.8 1.4 1.95 2.5 3.3 3.3l13.75-23.8H1.2c0 1.55.4 3.1 1.2 4.5l4.2 9.35z" fill="#0066DA"/>
          <path d="M43.65 25.15L29.9 1.35c-1.35.8-2.5 1.9-3.3 3.3L1.2 52.7c-.8 1.4-1.2 2.95-1.2 4.5h27.5l16.15-32.05z" fill="#00AC47"/>
          <path d="M73.55 76.8c1.35-.8 2.5-1.9 3.3-3.3l1.6-2.75 7.65-13.25c.8-1.4 1.2-2.95 1.2-4.5H59.85L55 62.1l-1.45 2.55L73.55 76.8z" fill="#EA4335"/>
          <path d="M43.65 25.15L57.4 1.35C56.05.55 54.5 0 52.9 0H34.4c-1.6 0-3.15.55-4.5 1.35l13.75 23.8z" fill="#00832D"/>
          <path d="M59.85 53H27.5L13.75 76.8c1.35.8 2.9 1.2 4.5 1.2H69.05c1.6 0 3.15-.45 4.5-1.2L59.85 53z" fill="#2684FC"/>
          <path d="M73.4 26.5l-12.7-22c-.8-1.4-1.95-2.5-3.3-3.3L43.65 25.15 59.85 53h27.45c0-1.55-.4-3.1-1.2-4.5L73.4 26.5z" fill="#FFBA00"/>
        </svg>
        google drive
      </a>
    </div>
  </section>

  <!-- Try it -->
  <section class="border-t border-gh-border py-12 sm:py-14">
    <div class="mx-auto max-w-3xl px-6">
      <p class="text-sm font-bold uppercase tracking-[0.2em] text-gh-blue">
        // try these questions
      </p>

      <div class="mt-10">
        <p class="text-sm font-bold text-gh-fg">
          <span class="text-gh-green">[ok]</span> the agent will answer
        </p>
        <p class="mt-1 text-xs text-gh-fg-muted">
          questions matching products in the knowledge base &mdash; expect a sourced reply.
        </p>
        <ul class="mt-4 space-y-2">
          {canAnswer.map(q => (
            <li class="flex items-start justify-between gap-3 border-b border-gh-border py-2 last:border-b-0">
              <span class="text-xs leading-relaxed text-gh-fg-muted">{q}</span>
              <button
                data-copy-question
                data-copy-text={q}
                aria-label="Copy question"
                class="shrink-0 rounded-md border border-gh-border bg-gh-canvas-subtle px-2 py-0.5 text-[10px] font-semibold uppercase text-gh-fg-muted transition-colors hover:bg-white hover:text-gh-fg cursor-pointer"
              >
                <span class="copy-label">copy</span>
              </button>
            </li>
          ))}
        </ul>
      </div>

      <div class="mt-12">
        <p class="text-sm font-bold text-gh-fg">
          <span class="text-gh-fg-subtle">[skip]</span> the agent will decline
        </p>
        <p class="mt-1 text-xs text-gh-fg-muted">
          products not in the knowledge base &mdash; expect a polite refusal, not a guess.
        </p>
        <ul class="mt-4 space-y-2">
          {willDecline.map(q => (
            <li class="flex items-start justify-between gap-3 border-b border-gh-border py-2 last:border-b-0">
              <span class="text-xs leading-relaxed text-gh-fg-muted">{q}</span>
              <button
                data-copy-question
                data-copy-text={q}
                aria-label="Copy question"
                class="shrink-0 rounded-md border border-gh-border bg-gh-canvas-subtle px-2 py-0.5 text-[10px] font-semibold uppercase text-gh-fg-muted transition-colors hover:bg-white hover:text-gh-fg cursor-pointer"
              >
                <span class="copy-label">copy</span>
              </button>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- Under the hood -->
  <section class="border-t border-gh-border py-12 sm:py-14">
    <div class="mx-auto max-w-5xl px-6">
      <p class="text-sm font-bold uppercase tracking-[0.2em] text-gh-blue">
        // under the hood
      </p>
      <p class="mt-6 max-w-2xl text-sm leading-relaxed text-gh-fg-muted">
        For technical reviewers &mdash; the stack and the reasoning.
      </p>

      <div class="mt-10 grid gap-10 sm:grid-cols-3 sm:gap-8">
        {stack.map(layer => (
          <div class="animate-on-scroll">
            <div class="flex items-baseline gap-2 text-xs text-gh-fg-subtle">
              <span>{layer.num}</span>
              <span class="h-px flex-1 bg-gh-border"></span>
            </div>
            <h3 class="mt-3 text-sm font-bold text-gh-fg">{layer.title}</h3>
            <p class="mt-2 text-xs leading-relaxed text-gh-fg-muted">{layer.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <script>
    const btn = document.getElementById('copy-email-btn');
    const label = document.getElementById('copy-label');
    const icon = document.getElementById('copy-icon');

    btn?.addEventListener('click', () => {
      navigator.clipboard.writeText('demo@lab5.ca').then(() => {
        if (label) label.textContent = '✓ copied';
        if (icon) (icon as HTMLElement).style.display = 'none';
        setTimeout(() => {
          if (label) label.textContent = 'copy';
          if (icon) (icon as HTMLElement).style.display = '';
        }, 2000);
      });
    });

    document.querySelectorAll('[data-copy-question]').forEach(btn => {
      btn.addEventListener('click', () => {
        const text = btn.getAttribute('data-copy-text') || '';
        const labelEl = btn.querySelector('.copy-label');
        navigator.clipboard.writeText(text).then(() => {
          if (labelEl) labelEl.textContent = '✓';
          setTimeout(() => {
            if (labelEl) labelEl.textContent = 'copy';
          }, 1500);
        });
      });
    });
  </script>
</Layout>
