---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import headshot from '../assets/konstantin-borovik-headshot.jpg';
---

<Layout
  title="About"
  description="Konstantin Borovik — AI Productivity Engineer. I modernize business operations with AI to make companies move faster. 20+ years in systems integration, cloud architecture, and AI automation."
>
  <!-- Header -->
  <section class="mx-auto max-w-5xl px-6 py-20">
    <p class="text-sm font-semibold uppercase tracking-widest text-gh-green">About</p>
    <h1 class="mt-2 text-4xl font-bold tracking-tight text-gh-fg sm:text-5xl">
      Building technology that works
    </h1>
  </section>

  <!-- Bio -->
  <section class="border-t border-gh-border bg-gh-canvas-subtle py-20">
    <div class="mx-auto max-w-5xl px-6">
      <div class="grid gap-12 sm:grid-cols-3 sm:items-start">

        <!-- Headshot -->
        <Image
          src={headshot}
          alt="Konstantin Borovik"
          width={400}
          height={400}
          class="mx-auto h-48 w-48 rounded-2xl object-cover object-top sm:mx-0"
        />

        <!-- Bio -->
        <div class="sm:col-span-2">
          <h2 class="text-2xl font-bold text-gh-fg">Konstantin Borovik</h2>
          <p class="mt-1 text-base font-medium text-gh-green">AI Productivity Engineer</p>

          <div class="mt-6 space-y-4 leading-relaxed text-gh-fg-muted">
            <p>
              20+ years progressing from systems engineering to cloud architecture to building
              production AI. From enterprise data centers to global payment infrastructure
              to commercial real estate platforms &mdash; I've built and led at every scale.
            </p>
            <p>
              What I do now: I automate repetitive business processes with AI. Email, documents,
              workflows, data entry &mdash; if your team does it manually and it follows a pattern,
              AI can handle it.
            </p>
            <p>
              I'm looking for a company where I can make business operations faster with AI.
              Ideal fit: a company where manual processes are the bottleneck and leadership
              is ready to invest in automation.
            </p>
            <p>
              I built MailPilot to demonstrate my approach: identify a real business problem,
              automate it with AI, and deploy to production. The site you're on right now
              is part of that &mdash; Astro, Tailwind, Cloudflare Workers.
            </p>
          </div>

          <div class="mt-8 flex flex-wrap gap-3">
            <a
              href="https://www.linkedin.com/in/kborovik"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 rounded-lg bg-gh-blue px-5 py-2.5 text-sm font-semibold text-white transition-colors hover:bg-gh-blue-hover"
            >
              <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.5 2h-17A1.5 1.5 0 002 3.5v17A1.5 1.5 0 003.5 22h17a1.5 1.5 0 001.5-1.5v-17A1.5 1.5 0 0020.5 2zM8 19H5v-9h3zM6.5 8.25A1.75 1.75 0 118.3 6.5a1.78 1.78 0 01-1.8 1.75zM19 19h-3v-4.74c0-1.42-.6-1.93-1.38-1.93A1.74 1.74 0 0013 14.19a.66.66 0 000 .14V19h-3v-9h2.9v1.3a3.11 3.11 0 012.7-1.4c1.55 0 3.36.86 3.36 3.66z" /></svg>
              LinkedIn
            </a>
            <a
              href="https://github.com/kborovik/"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 rounded-lg border border-gh-border bg-white px-5 py-2.5 text-sm font-semibold text-gh-fg transition-colors hover:bg-gh-canvas-subtle"
            >
              <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/></svg>
              GitHub
            </a>
            <a
              href="https://calendar.app.google/cYM3H3TsHsequR587"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 rounded-lg bg-gh-green px-5 py-2.5 text-sm font-semibold text-white transition-colors hover:bg-gh-green-hover"
            >
              <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor"><path d="M19 4h-1V2h-2v2H8V2H6v2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 16H5V10h14v10zm0-12H5V6h14v2zM7 12h5v5H7v-5z"/></svg>
              Book a Call
            </a>
          </div>
        </div>

      </div>
    </div>
  </section>

</Layout>
