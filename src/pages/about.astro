---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import headshot from '../assets/konstantin-borovik-headshot.jpg';
---

<Layout
  title="About"
  schemaType="ProfilePage"
  description="Konstantin Borovik — AI Automation Engineer based in Toronto, Canada. 20+ years across systems engineering, cloud architecture, and production AI."
>
  <!-- Header -->
  <section class="mx-auto max-w-5xl px-6 pt-16 pb-8 sm:pt-20 sm:pb-10">
    <p class="text-base font-bold uppercase tracking-[0.2em] text-gh-blue">
      // about
    </p>
    <h1 class="mt-4 text-3xl font-bold tracking-tight text-gh-fg sm:text-4xl">
      Konstantin Borovik
    </h1>
    <p class="mt-3 text-sm text-gh-fg-muted">
      AI Automation Engineer &middot; 20+ years engineering
    </p>
    <address class="mt-1 text-sm not-italic text-gh-fg-muted">
      Toronto, Ontario, Canada
    </address>
  </section>

  <!-- Bio -->
  <section class="border-t border-gh-border py-12 sm:py-14">
    <div class="mx-auto max-w-5xl px-6">
      <div class="grid gap-12 sm:grid-cols-3 sm:items-start">

        <Image
          src={headshot}
          alt="Konstantin Borovik"
          width={400}
          height={400}
          class="mx-auto h-48 w-48 rounded-lg border border-gh-border object-cover object-top sm:mx-0"
        />

        <div class="sm:col-span-2">
          <div class="space-y-4 text-sm leading-relaxed text-gh-fg-muted sm:text-base">
            <p>
              20+ years progressing from systems engineering to cloud architecture to production AI. From enterprise data centers to global payment infrastructure to commercial real estate platforms &mdash; built and led at every scale.
            </p>
            <p>
              What I do now: automate repetitive business processes with AI. ERP integration, document workflows, email, and reporting &mdash; if a team does it manually and it follows a pattern, AI can handle it.
            </p>
            <p>
              Looking for a company where manual processes are the bottleneck and leadership is ready to invest in automation.
            </p>
            <p>
              MailPilot demonstrates the approach: find a real business problem, automate it with AI, ship to production. This site is part of that &mdash; Astro, Tailwind, Cloudflare Workers.
            </p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Claims -->
  <section class="border-t border-gh-border py-12 sm:py-14">
    <div class="mx-auto max-w-5xl px-6">
      <p class="text-base font-bold uppercase tracking-[0.2em] text-gh-blue">
        // claims
      </p>
      <ul class="mt-6 space-y-2 text-sm leading-relaxed text-gh-fg-muted sm:text-base">
        <li class="flex gap-3">
          <span class="text-gh-fg-muted">&minus;</span>
          <span>20+ years shipping production systems &mdash; data centers, global payments, commercial real estate, automation</span>
        </li>
        <li class="flex gap-3">
          <span class="text-gh-fg-muted">&minus;</span>
          <span>Python and TypeScript daily; production LLM agents on Pydantic AI and the Claude API</span>
        </li>
        <li class="flex gap-3">
          <span class="text-gh-fg-muted">&minus;</span>
          <span>MailPilot built end-to-end: agent, Cloudflare Workers, IaC, deploy &mdash; one engineer, the whole pipeline</span>
        </li>
        <li class="flex gap-3">
          <span class="text-gh-fg-muted">&minus;</span>
          <span>Current focus: AI automation for ERP integration, document workflows, email, and reporting</span>
        </li>
      </ul>
    </div>
  </section>

  <!-- Proof -->
  <section class="border-t border-gh-border py-12 sm:py-14">
    <div class="mx-auto max-w-5xl px-6">
      <p class="text-base font-bold uppercase tracking-[0.2em] text-gh-blue">
        // proof
      </p>
      <div class="mt-6 flex flex-wrap gap-3">
        <a
          href="/resume"
          class="inline-flex items-center gap-2 rounded-lg border border-gh-border bg-white px-4 py-2 text-sm font-bold text-gh-fg transition-colors hover:bg-gh-canvas-subtle"
        >
          <svg class="h-4 w-4 text-gh-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
          resume
        </a>
        <a
          href="https://www.linkedin.com/in/kborovik"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-lg border border-gh-border bg-white px-4 py-2 text-sm font-bold text-gh-fg transition-colors hover:bg-gh-canvas-subtle"
        >
          <svg class="h-4 w-4 text-gh-blue" fill="currentColor" viewBox="0 0 24 24"><path d="M20.5 2h-17A1.5 1.5 0 002 3.5v17A1.5 1.5 0 003.5 22h17a1.5 1.5 0 001.5-1.5v-17A1.5 1.5 0 0020.5 2zM8 19H5v-9h3zM6.5 8.25A1.75 1.75 0 118.3 6.5a1.78 1.78 0 01-1.8 1.75zM19 19h-3v-4.74c0-1.42-.6-1.93-1.38-1.93A1.74 1.74 0 0013 14.19a.66.66 0 000 .14V19h-3v-9h2.9v1.3a3.11 3.11 0 012.7-1.4c1.55 0 3.36.86 3.36 3.66z" /></svg>
          linkedin
        </a>
        <a
          href="https://github.com/kborovik"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-lg border border-gh-border bg-white px-4 py-2 text-sm font-bold text-gh-fg transition-colors hover:bg-gh-canvas-subtle"
        >
          <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/></svg>
          github
        </a>
        <a
          href="https://github.com/kborovik/mailpilot"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-lg border border-gh-border bg-white px-4 py-2 text-sm font-bold text-gh-fg transition-colors hover:bg-gh-canvas-subtle"
        >
          <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/></svg>
          MailPilot source
        </a>
        <a
          href="/blog"
          class="inline-flex items-center gap-2 rounded-lg border border-gh-border bg-white px-4 py-2 text-sm font-bold text-gh-fg transition-colors hover:bg-gh-canvas-subtle"
        >
          <svg class="h-4 w-4 text-gh-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" />
          </svg>
          blog
        </a>
      </div>
    </div>
  </section>
</Layout>
