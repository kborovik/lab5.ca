---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import headshot from '../assets/konstantin-borovik-headshot.jpg';
---

<Layout
  title="About"
  description="Konstantin Borovik — Tech Lead for Business Modernization. I modernize business operations with Google Cloud. 20+ years in systems integration, cloud architecture, and technical leadership."
>
  <!-- Header -->
  <section class="mx-auto max-w-5xl px-6 py-20">
    <p class="text-sm font-semibold uppercase tracking-widest text-gh-green">About</p>
    <h1 class="mt-2 text-4xl font-bold tracking-tight text-gh-fg sm:text-5xl">
      Building technology<br />that works.
    </h1>
  </section>

  <!-- Bio -->
  <section class="border-t border-gh-border bg-gh-canvas-subtle py-20">
    <div class="mx-auto max-w-5xl px-6">
      <div class="grid gap-12 sm:grid-cols-3 sm:items-start">

        <!-- Headshot -->
        <Image
          src={headshot}
          alt="Konstantin Borovik"
          width={400}
          height={400}
          class="mx-auto h-48 w-48 rounded-2xl object-cover object-top sm:mx-0"
        />

        <!-- Bio -->
        <div class="sm:col-span-2">
          <h2 class="text-2xl font-bold text-gh-fg">Konstantin Borovik</h2>
          <p class="mt-1 text-base font-medium text-gh-green">Tech Lead for Business Modernization</p>

          <div class="mt-6 space-y-4 leading-relaxed text-gh-fg-muted">
            <p>
              20+ years progressing from systems engineering to cloud architecture to building
              production platforms on Google Cloud. From enterprise data centers to global payment
              infrastructure to commercial real estate platforms &mdash; I've built and led at every scale.
            </p>
            <p>
              What I do: systems integration (ERP, CRM, custom software) with Google Cloud
              Technologies. I connect disconnected business systems, automate manual workflows,
              and bring technical leadership to companies that have outgrown their current setup.
            </p>
            <p>
              I'm looking for a company where I can modernize business operations with Google Cloud.
              Ideal fit: a company using (or open to) Google Workspace and GCP that needs someone
              who writes code every day, makes architecture decisions, and builds engineering teams.
            </p>
            <p>
              I built MailPilot to demonstrate my approach: identify a real business problem,
              design the architecture, build it end-to-end on GCP, and deploy to production.
              The site you're on right now is part of that &mdash; Astro, Tailwind, Cloudflare Workers.
            </p>
          </div>

          <div class="mt-8 flex flex-wrap gap-3">
            <a
              href="https://www.linkedin.com/in/kborovik"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 rounded-lg bg-gh-blue px-5 py-2.5 text-sm font-semibold text-white transition-colors hover:bg-gh-blue-hover"
            >
              <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.5 2h-17A1.5 1.5 0 002 3.5v17A1.5 1.5 0 003.5 22h17a1.5 1.5 0 001.5-1.5v-17A1.5 1.5 0 0020.5 2zM8 19H5v-9h3zM6.5 8.25A1.75 1.75 0 118.3 6.5a1.78 1.78 0 01-1.8 1.75zM19 19h-3v-4.74c0-1.42-.6-1.93-1.38-1.93A1.74 1.74 0 0013 14.19a.66.66 0 000 .14V19h-3v-9h2.9v1.3a3.11 3.11 0 012.7-1.4c1.55 0 3.36.86 3.36 3.66z" /></svg>
              LinkedIn
            </a>
            <a
              href="https://calendar.app.google/cYM3H3TsHsequR587"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 rounded-lg bg-gh-green px-5 py-2.5 text-sm font-semibold text-white transition-colors hover:bg-gh-green-hover"
            >
              <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor"><path d="M19 4h-1V2h-2v2H8V2H6v2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 16H5V10h14v10zm0-12H5V6h14v2zM7 12h5v5H7v-5z"/></svg>
              Book a Call
            </a>
          </div>
        </div>

      </div>
    </div>
  </section>

</Layout>
