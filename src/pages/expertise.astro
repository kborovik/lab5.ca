---
import Layout from '../layouts/Layout.astro';

const sections = [
  {
    id: 'erp',
    num: '01',
    title: 'ERP Integration',
    description:
      'Connect ERP, accounting, CRM, and document stores so orders, approvals, and reporting run end-to-end. Each step triggered by the upstream event, idempotent, observable.',
    capabilities: [
      'ERP / accounting / CRM integration (NetSuite, QuickBooks, Xero, Salesforce, HubSpot)',
      'approval and routing automation',
      'order processing and fulfillment tracking',
      'onboarding and compliance workflows',
    ],
    stack: [
      ['trigger', 'webhook / event / cron'],
      ['orchestrate', 'idempotent state machine'],
      ['integrate', 'erp / accounting / crm'],
      ['infra', 'terraform, github actions'],
      ['observe', 'structured logs, traces'],
    ],
  },
  {
    id: 'documents',
    num: '02',
    title: 'Document Workflow',
    description:
      'Extract data from invoices, contracts, purchase orders, and forms automatically. AI reads documents, pulls the data, and writes it to the system of record — no manual data entry.',
    capabilities: [
      'invoice and PO data extraction',
      'contract and form processing',
      'automated filing and categorization',
      'data validation and error detection',
    ],
    stack: [
      ['intake', 'file watchers, attachments'],
      ['extract', 'ocr + llm structured output'],
      ['validate', 'schema + confidence score'],
      ['route', 'erp / crm / accounting'],
      ['audit', 'immutable log per doc'],
    ],
  },
  {
    id: 'email',
    num: '03',
    title: 'AI Email & Communication',
    description:
      'Automate email triage, draft responses, handle customer inquiries, and route messages to the right person. AI handles routine communication; the team handles what AI can’t.',
    capabilities: [
      'email triage and auto-response',
      'customer inquiry handling',
      'internal communication routing',
      'follow-up and reminder automation',
    ],
    stack: [
      ['trigger', 'gmail push api'],
      ['extract', 'llm w/ structured prompts'],
      ['retrieve', 'vector store over kb'],
      ['runtime', 'serverless functions'],
      ['output', 'gmail api drafts'],
    ],
  },
  {
    id: 'data',
    num: '04',
    title: 'Data & Reporting',
    description:
      'Aggregate data from scattered systems, generate summaries with citations, and surface what changed. The reports your team used to build by hand, generated on a schedule.',
    capabilities: [
      'cross-system data aggregation',
      'automated report generation',
      'trend detection and anomaly alerts',
      'dashboard and summary creation',
    ],
    stack: [
      ['sources', 'db, sheets, exports, apis'],
      ['aggregate', 'scheduled jobs, queries'],
      ['narrate', 'llm summary w/ citations'],
      ['deliver', 'email digest, slack, drive'],
      ['schedule', 'cron / on-demand'],
    ],
  },
];

const industries = [
  'logistics',
  'distribution',
  'construction',
  'insurance',
  'manufacturing',
  'accounting',
  'property management',
];
---

<Layout
  title="Expertise"
  description="AI-powered automation for email, documents, workflows, and reporting — 20+ years of hands-on engineering experience."
>
  <!-- Header -->
  <section class="mx-auto max-w-5xl px-6 pt-16 pb-8 sm:pt-20 sm:pb-10">
    <p class="text-sm font-bold uppercase tracking-[0.2em] text-gh-blue">
      // expertise
    </p>
    <h1 class="mt-4 text-3xl font-bold tracking-tight text-gh-fg sm:text-4xl">
      What I build
    </h1>
    <p class="mt-4 max-w-2xl text-sm leading-relaxed text-gh-fg-muted sm:text-base">
      Twenty years of hands-on engineering &mdash; infrastructure, cloud, AI. I work with companies where manual processes and disconnected systems are the bottleneck.
    </p>
    <p class="mt-6 text-xs text-gh-fg-muted">
      industries: {industries.join(' · ')}
    </p>
  </section>

  {sections.map(section => (
    <section id={section.id} class="border-t border-gh-border py-12 sm:py-14">
      <div class="mx-auto max-w-5xl px-6">
        <div class="animate-on-scroll grid gap-10 sm:grid-cols-3 sm:gap-12">

          <div class="sm:col-span-2">
            <div class="flex items-baseline gap-2 text-xs text-gh-fg-muted">
              <span>{section.num}</span>
              <span class="h-px flex-1 bg-gh-border"></span>
            </div>
            <h2 class="mt-3 text-xl font-bold tracking-tight text-gh-fg sm:text-2xl">
              {section.title}
            </h2>
            <p class="mt-4 text-sm leading-relaxed text-gh-fg-muted">
              {section.description}
            </p>
            <ul class="mt-6 space-y-1.5 text-sm text-gh-fg-muted">
              {section.capabilities.map(item => (
                <li class="flex gap-3">
                  <span class="text-gh-fg-muted">&minus;</span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>

          <aside class="rounded-lg border border-gh-border bg-gh-canvas-subtle p-5">
            <p class="text-xs font-bold uppercase tracking-[0.15em] text-gh-fg-muted">
              implementation
            </p>
            <dl class="mt-4 space-y-2 text-xs">
              {section.stack.map(([key, value]) => (
                <div class="grid grid-cols-[6rem_1fr] gap-2">
                  <dt class="text-gh-fg-muted">{key}</dt>
                  <dd class="text-gh-fg">{value}</dd>
                </div>
              ))}
            </dl>
          </aside>

        </div>
      </div>
    </section>
  ))}
</Layout>
