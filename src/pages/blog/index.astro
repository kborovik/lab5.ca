---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const dateFmt = new Intl.DateTimeFormat('en-CA', {
  year: 'numeric',
  month: 'short',
  day: '2-digit',
  timeZone: 'UTC',
});
---

<Layout
  title="Blog"
  description="Notes on cloud infrastructure, AI agents for business workflows, and web development."
>
  <!-- Header -->
  <section class="mx-auto max-w-5xl px-6 pt-16 pb-8 sm:pt-20 sm:pb-10">
    <p class="text-base font-bold uppercase tracking-[0.2em] text-gh-blue">
      // blog
    </p>
    <h1 class="mt-4 text-3xl font-bold tracking-tight text-gh-fg sm:text-4xl">
      Notes
    </h1>
    <p class="mt-4 max-w-2xl text-sm leading-relaxed text-gh-fg-muted sm:text-base">
      Field notes on cloud infrastructure, AI agents, and the boring engineering
      that decides whether a system runs for a quarter or five years.
    </p>
  </section>

  <!-- Posts -->
  <section class="border-t border-gh-border py-12 sm:py-14">
    <div class="mx-auto max-w-5xl px-6">
      {posts.length === 0 ? (
        <p class="text-sm text-gh-fg-muted">No posts yet.</p>
      ) : (
        <ul class="space-y-10">
          {posts.map((post, i) => (
            <li class="animate-on-scroll">
              <div class="flex items-baseline gap-2 text-xs text-gh-fg-muted">
                <span>{String(i + 1).padStart(2, '0')}</span>
                <span class="h-px flex-1 bg-gh-border"></span>
                <time datetime={post.data.pubDate.toISOString()}>
                  {dateFmt.format(post.data.pubDate)}
                </time>
              </div>
              <h2 class="mt-3 text-xl font-bold tracking-tight text-gh-fg sm:text-2xl">
                <a href={`/blog/${post.id}`} class="text-gh-green hover:text-gh-green-hover underline underline-offset-[3px]">
                  {post.data.title}
                </a>
              </h2>
              <p class="mt-3 max-w-3xl text-sm leading-relaxed text-gh-fg-muted">
                {post.data.description}
              </p>
              {post.data.tags.length > 0 && (
                <p class="mt-3 text-xs text-gh-fg-muted">
                  tags: {post.data.tags.join(' · ')}
                </p>
              )}
              <p class="mt-4">
                <a
                  href={`/blog/${post.id}`}
                  class="text-xs font-bold uppercase tracking-[0.15em] text-gh-green hover:text-gh-green-hover underline underline-offset-[3px]"
                >
                  read &rarr;
                </a>
              </p>
            </li>
          ))}
        </ul>
      )}
    </div>
  </section>
</Layout>
