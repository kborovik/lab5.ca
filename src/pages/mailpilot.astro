---
import Layout from '../layouts/Layout.astro';
import {
  kicker,
  intro,
  email,
  emailNote,
  sections,
  steps,
  knowledgeBase,
  tryThese,
  underTheHood,
} from '../copy/mailpilot';
---

<Layout
  title="MailPilot"
  description="AI agent for business email — MailPilot, a production Pydantic AI agent I built end-to-end on Google Cloud. Email it a question; the reply is evidence of the work."
  markdownAlternate="/mailpilot.md"
>
  <!-- Header -->
  <section class="mx-auto max-w-3xl px-6 pt-16 pb-8 sm:pt-20 sm:pb-10 text-center">
    <p class="section-kicker text-base font-bold uppercase tracking-[0.2em] text-gh-blue">
      {kicker}
    </p>
    <h1 class="mt-4 text-3xl font-bold tracking-tight text-gh-fg sm:text-4xl">
      MailPilot
    </h1>
    <p class="mx-auto mt-4 max-w-xl text-sm leading-relaxed text-gh-fg-muted sm:text-base">
      {intro}
    </p>

    <div class="mt-10 inline-flex items-center gap-3 rounded-lg border border-gh-border bg-gh-canvas-subtle px-5 py-3 text-sm text-gh-fg">
      <span class="text-gh-fg-muted">$</span>
      <span>mail {email}</span>
      <button
        id="copy-email-btn"
        aria-label="Copy email address"
        class="flex items-center gap-1.5 rounded-md border border-gh-border bg-white px-2.5 py-1 text-xs font-semibold text-gh-fg-muted transition-colors hover:text-gh-fg cursor-pointer"
      >
        <svg id="copy-icon" class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
        </svg>
        <span id="copy-label">copy</span>
      </button>
    </div>

    <p class="mt-4 text-xs text-gh-fg-muted">
      {emailNote}
    </p>
  </section>

  <!-- How it works -->
  <section class="border-t border-gh-border py-12 sm:py-14">
    <div class="mx-auto max-w-3xl px-6">
      <h2 class="section-kicker text-base font-bold uppercase tracking-[0.2em] text-gh-blue">
        {sections.howItWorks}
      </h2>
      <div class="mt-10 grid gap-10 sm:grid-cols-3 sm:gap-8">
        {steps.map(step => (
          <div class="animate-on-scroll">
            <div class="flex items-baseline gap-2 text-xs text-gh-fg-muted">
              <span>{step.num}</span>
              <span class="h-px flex-1 bg-gh-border"></span>
            </div>
            <h3 class="mt-3 text-sm font-bold text-gh-fg">{step.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-gh-fg-muted">{step.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Knowledge base -->
  <section class="border-t border-gh-border py-12 sm:py-14">
    <div class="mx-auto max-w-3xl px-6">
      <p class="text-base font-bold uppercase tracking-[0.2em] text-gh-blue">
        // {sections.knowledgeBase}
      </p>
      <p class="mt-6 max-w-2xl text-sm leading-relaxed text-gh-fg-muted">
        {knowledgeBase.body}
      </p>
      <a
        href={knowledgeBase.driveUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="mt-6 inline-flex items-center gap-2 rounded-lg border border-gh-border bg-white px-4 py-2 text-sm font-bold text-gh-fg transition-colors hover:bg-gh-canvas-subtle"
      >
        <svg class="h-4 w-4" viewBox="0 0 87.3 78" fill="currentColor">
          <path d="M6.6 66.85l3.85 6.65c.8 1.4 1.95 2.5 3.3 3.3l13.75-23.8H1.2c0 1.55.4 3.1 1.2 4.5l4.2 9.35z" fill="#0066DA"/>
          <path d="M43.65 25.15L29.9 1.35c-1.35.8-2.5 1.9-3.3 3.3L1.2 52.7c-.8 1.4-1.2 2.95-1.2 4.5h27.5l16.15-32.05z" fill="#00AC47"/>
          <path d="M73.55 76.8c1.35-.8 2.5-1.9 3.3-3.3l1.6-2.75 7.65-13.25c.8-1.4 1.2-2.95 1.2-4.5H59.85L55 62.1l-1.45 2.55L73.55 76.8z" fill="#EA4335"/>
          <path d="M43.65 25.15L57.4 1.35C56.05.55 54.5 0 52.9 0H34.4c-1.6 0-3.15.55-4.5 1.35l13.75 23.8z" fill="#00832D"/>
          <path d="M59.85 53H27.5L13.75 76.8c1.35.8 2.9 1.2 4.5 1.2H69.05c1.6 0 3.15-.45 4.5-1.2L59.85 53z" fill="#2684FC"/>
          <path d="M73.4 26.5l-12.7-22c-.8-1.4-1.95-2.5-3.3-3.3L43.65 25.15 59.85 53h27.45c0-1.55-.4-3.1-1.2-4.5L73.4 26.5z" fill="#FFBA00"/>
        </svg>
        google drive
      </a>
    </div>
  </section>

  <!-- Try it -->
  <section class="border-t border-gh-border py-12 sm:py-14">
    <div class="mx-auto max-w-3xl px-6">
      <p class="text-base font-bold uppercase tracking-[0.2em] text-gh-blue">
        // {sections.tryThese}
      </p>

      <div class="mt-10">
        <p class="text-sm font-bold text-gh-fg">
          <span class="text-gh-green">[ok]</span> {tryThese.answer.heading}
        </p>
        <p class="mt-1 text-xs text-gh-fg-muted">
          {tryThese.answer.hint}
        </p>
        <ul class="mt-4 space-y-2">
          {tryThese.answer.questions.map(q => (
            <li class="flex items-start justify-between gap-3 border-b border-gh-border py-2 last:border-b-0">
              <span class="text-sm leading-relaxed text-gh-fg-muted">{q}</span>
              <button
                data-copy-question
                data-copy-text={q}
                aria-label="Copy question"
                class="shrink-0 rounded-md border border-gh-border bg-gh-canvas-subtle px-2 py-0.5 text-[10px] font-semibold uppercase text-gh-fg-muted transition-colors hover:bg-white hover:text-gh-fg cursor-pointer"
              >
                <span class="copy-label">copy</span>
              </button>
            </li>
          ))}
        </ul>
      </div>

      <div class="mt-12">
        <p class="text-sm font-bold text-gh-fg">
          <span class="text-gh-fg-muted">[skip]</span> {tryThese.decline.heading}
        </p>
        <p class="mt-1 text-xs text-gh-fg-muted">
          {tryThese.decline.hint}
        </p>
        <ul class="mt-4 space-y-2">
          {tryThese.decline.questions.map(q => (
            <li class="flex items-start justify-between gap-3 border-b border-gh-border py-2 last:border-b-0">
              <span class="text-sm leading-relaxed text-gh-fg-muted">{q}</span>
              <button
                data-copy-question
                data-copy-text={q}
                aria-label="Copy question"
                class="shrink-0 rounded-md border border-gh-border bg-gh-canvas-subtle px-2 py-0.5 text-[10px] font-semibold uppercase text-gh-fg-muted transition-colors hover:bg-white hover:text-gh-fg cursor-pointer"
              >
                <span class="copy-label">copy</span>
              </button>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- Under the hood -->
  <section class="border-t border-gh-border py-12 sm:py-14">
    <div class="mx-auto max-w-5xl px-6">
      <h2 class="section-kicker text-base font-bold uppercase tracking-[0.2em] text-gh-blue">
        {sections.underTheHood}
      </h2>
      <p class="mt-6 max-w-2xl text-sm leading-relaxed text-gh-fg-muted">
        {underTheHood.body}
      </p>

      <div class="mt-10 grid gap-10 sm:grid-cols-2 sm:gap-8">
        {underTheHood.stack.map(layer => (
          <div class="animate-on-scroll">
            <div class="flex items-baseline gap-2 text-xs text-gh-fg-muted">
              <span>{layer.num}</span>
              <span class="h-px flex-1 bg-gh-border"></span>
            </div>
            <h3 class="mt-3 text-sm font-bold text-gh-fg">{layer.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-gh-fg-muted">{layer.body}</p>
          </div>
        ))}
      </div>

      <a
        href={underTheHood.repoUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="mt-10 inline-flex items-center gap-2 rounded-lg border border-gh-border bg-white px-4 py-2 text-sm font-bold text-gh-fg transition-colors hover:bg-gh-canvas-subtle"
      >
        <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/></svg>
        github.com/kborovik/mailpilot
      </a>
    </div>
  </section>

  <script>
    const btn = document.getElementById('copy-email-btn');
    const label = document.getElementById('copy-label');
    const icon = document.getElementById('copy-icon');

    btn?.addEventListener('click', () => {
      navigator.clipboard.writeText('hello@lab5.ca').then(() => {
        if (label) label.textContent = '✓ copied';
        if (icon) (icon as HTMLElement).style.display = 'none';
        setTimeout(() => {
          if (label) label.textContent = 'copy';
          if (icon) (icon as HTMLElement).style.display = '';
        }, 2000);
      });
    });

    document.querySelectorAll('[data-copy-question]').forEach(btn => {
      btn.addEventListener('click', () => {
        const text = btn.getAttribute('data-copy-text') || '';
        const labelEl = btn.querySelector('.copy-label');
        navigator.clipboard.writeText(text).then(() => {
          if (labelEl) labelEl.textContent = '✓';
          setTimeout(() => {
            if (labelEl) labelEl.textContent = 'copy';
          }, 1500);
        });
      });
    });
  </script>
</Layout>
