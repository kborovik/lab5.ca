---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Resume"
  schemaType="ProfilePage"
  description="Konstantin Borovik — Software Developer | DevOps Engineer in Toronto, Canada. 20+ years engineering. Tech stack, projects, engagements, and education."
>
  <article class="resume mx-auto max-w-3xl px-6 py-12 sm:py-16">
    <!-- Contact -->
    <header class="resume-contact">
      <h1 class="text-3xl font-bold tracking-tight text-gh-fg sm:text-4xl">Software Developer | DevOps Engineer</h1>
      <p class="mt-4 text-sm text-gh-fg-muted">Konstantin Borovik &middot; 20+ years engineering</p>
      <address class="mt-1 text-sm not-italic text-gh-fg-muted">Toronto, Ontario, Canada</address>

      <ul class="resume-links mt-5 flex flex-wrap gap-x-5 gap-y-2 text-sm text-gh-fg-muted">
        <li>
          <a
            href="https://www.linkedin.com/in/kborovik"
            target="_blank"
            rel="noopener noreferrer"
            class="text-gh-green hover:text-gh-green-hover">linkedin.com/in/kborovik</a
          >
        </li>
        <li>
          <a href="https://github.com/kborovik" target="_blank" rel="noopener noreferrer" class="text-gh-green hover:text-gh-green-hover"
            >github.com/kborovik</a
          >
        </li>
        <li>
          <a href="/" class="text-gh-green hover:text-gh-green-hover">lab5.ca</a>
        </li>
      </ul>
    </header>

    <!-- Tech stack -->
    <section class="mt-12 border-t border-gh-border pt-10">
      <h2 class="text-base font-bold uppercase tracking-[0.2em] text-gh-blue">// tech stack</h2>

      <div class="mt-8 space-y-6 text-sm leading-relaxed text-gh-fg-muted sm:text-base">
        <div>
          <h3 class="text-base font-semibold text-gh-fg">Programming languages</h3>
          <p class="mt-2">Python, TypeScript, Bash, SQL</p>
        </div>

        <div>
          <h3 class="text-base font-semibold text-gh-fg">Google Cloud</h3>
          <p class="mt-2">Cloud Run, Cloud Functions, BigQuery, Vertex AI, Cloud SQL, Composer, Pub/Sub</p>
        </div>

        <div>
          <h3 class="text-base font-semibold text-gh-fg">Azure</h3>
          <p class="mt-2">App Service, Functions, Service Bus, Key Vault</p>
        </div>

        <div>
          <h3 class="text-base font-semibold text-gh-fg">DevOps &amp; CI/CD</h3>
          <p class="mt-2">Terraform, Ansible, GitHub Actions, Azure DevOps, Docker, Kubernetes (GKE)</p>
        </div>

        <div>
          <h3 class="text-base font-semibold text-gh-fg">AI &amp; agents</h3>
          <p class="mt-2">
            Pydantic AI, LLM agents and agentic workflows, RAG, structured-extraction pipelines, MCP
          </p>
        </div>

        <div>
          <h3 class="text-base font-semibold text-gh-fg">APIs &amp; integration</h3>
          <p class="mt-2">REST, event-driven, Pub/Sub patterns, webhooks, OpenAPI</p>
        </div>

        <div>
          <h3 class="text-base font-semibold text-gh-fg">Security &amp; compliance</h3>
          <p class="mt-2">IAM, NIST-800-53, PCI-DSS, secrets management</p>
        </div>

        <div>
          <h3 class="text-base font-semibold text-gh-fg">SQL databases</h3>
          <p class="mt-2">PostgreSQL, SQLite</p>
        </div>

        <div>
          <h3 class="text-base font-semibold text-gh-fg">Web development</h3>
          <p class="mt-2">Astro, Cloudflare Workers</p>
        </div>
      </div>
    </section>

    <!-- Projects -->
    <section class="mt-12 border-t border-gh-border pt-10">
      <h2 class="text-base font-bold uppercase tracking-[0.2em] text-gh-blue">// projects</h2>

      <div class="mt-8 space-y-6">
        <article>
          <h3 class="text-base font-semibold text-gh-fg">MailPilot</h3>
          <p class="mt-1 text-sm leading-relaxed text-gh-fg-muted sm:text-base">
            Pydantic AI agent for business email &mdash; LLM workflows on a Google Cloud backend; live at demo@lab5.ca.
          </p>
          <p class="mt-2">
            <a
              href="https://github.com/kborovik/mailpilot"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 rounded-lg border border-gh-border bg-white px-3 py-1.5 text-xs font-bold text-gh-fg transition-colors hover:bg-gh-canvas-subtle"
            >
              github.com/kborovik/mailpilot
            </a>
          </p>
        </article>

        <article>
          <h3 class="text-base font-semibold text-gh-fg">gcp-devops</h3>
          <p class="mt-1 text-sm leading-relaxed text-gh-fg-muted sm:text-base">
            Reference Terraform / Ansible / IaC patterns for Google Cloud &mdash; Cloud Run, Pub/Sub, observability.
          </p>
          <p class="mt-2">
            <a
              href="https://github.com/kborovik/gcp-devops"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 rounded-lg border border-gh-border bg-white px-3 py-1.5 text-xs font-bold text-gh-fg transition-colors hover:bg-gh-canvas-subtle"
            >
              github.com/kborovik/gcp-devops
            </a>
          </p>
        </article>

        <article>
          <h3 class="text-base font-semibold text-gh-fg">Pilot Skills</h3>
          <p class="mt-1 text-sm leading-relaxed text-gh-fg-muted sm:text-base">
            Claude Code skills SDK plugins &mdash; spec-driven development and agentic workflows.
          </p>
          <p class="mt-2">
            <a
              href="https://github.com/kborovik/pilot-skills"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 rounded-lg border border-gh-border bg-white px-3 py-1.5 text-xs font-bold text-gh-fg transition-colors hover:bg-gh-canvas-subtle"
            >
              github.com/kborovik/pilot-skills
            </a>
          </p>
        </article>

        <article>
          <h3 class="text-base font-semibold text-gh-fg">lab5.ca</h3>
          <p class="mt-1 text-sm leading-relaxed text-gh-fg-muted sm:text-base">
            This site &mdash; Astro 6, Tailwind v4, TypeScript, Cloudflare Workers; spec-driven, deploy on push.
          </p>
          <p class="mt-2">
            <a
              href="https://github.com/kborovik/lab5.ca"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 rounded-lg border border-gh-border bg-white px-3 py-1.5 text-xs font-bold text-gh-fg transition-colors hover:bg-gh-canvas-subtle"
            >
              github.com/kborovik/lab5.ca
            </a>
          </p>
        </article>
      </div>
    </section>

    <!-- Engagements -->
    <section class="mt-12 border-t border-gh-border pt-10">
      <h2 class="text-base font-bold uppercase tracking-[0.2em] text-gh-blue">// engagements</h2>

      <div class="mt-8 space-y-10">
        <article>
          <div class="flex flex-wrap items-baseline justify-between gap-x-4">
            <h3 class="text-base font-semibold text-gh-fg">lab5.ca</h3>
            <span class="text-xs text-gh-fg-muted">2026 &mdash; present</span>
          </div>
          <p class="mt-1 text-base font-medium text-gh-fg">Independent contractor &middot; Software Developer | DevOps Engineer</p>
          <p class="mt-3 text-sm leading-relaxed text-gh-fg sm:text-base">
            I run an independent practice delivering cloud infrastructure, AI agents for business workflows,
            and web development end-to-end. MailPilot is my live proof-of-capability project (open source).
          </p>
          <ul class="mt-3 space-y-1.5 text-sm leading-relaxed text-gh-fg-muted sm:text-base">
            <li class="flex gap-3">
              <span class="text-gh-fg-muted">&minus;</span>
              <span
                >MailPilot &mdash; AI email automation, end-to-end (Python, PostgreSQL, Pub/Sub, Cloud Run, GCP)</span
              >
            </li>
            <li class="flex gap-3">
              <span class="text-gh-fg-muted">&minus;</span>
              <span>Pydantic AI agents, structured-extraction pipelines, idempotent state machines</span>
            </li>
          </ul>
        </article>

        <article>
          <div class="flex flex-wrap items-baseline justify-between gap-x-4">
            <h3 class="text-base font-semibold text-gh-fg">Colliers International</h3>
            <span class="text-xs text-gh-fg-muted">2023 &mdash; 2025</span>
          </div>
          <p class="mt-1 text-base font-medium text-gh-fg">Senior Software Engineer</p>
          <p class="mt-3 text-sm leading-relaxed text-gh-fg sm:text-base">
            I replaced manual data-processing workflows with serverless Python on GCP and Airflow ETL pipelines, backed
            by PostgreSQL for workflow state.
          </p>
          <ul class="mt-3 space-y-1.5 text-sm leading-relaxed text-gh-fg-muted sm:text-base">
            <li class="flex gap-3">
              <span class="text-gh-fg-muted">&minus;</span>
              <span
                >Event-driven Python services on Cloud Run and Cloud Functions, replacing manual data-processing
                workflows</span
              >
            </li>
            <li class="flex gap-3">
              <span class="text-gh-fg-muted">&minus;</span>
              <span
                >Airflow ETL orchestration; idempotent self-recovering pipelines replacing manual data transfers</span
              >
            </li>
            <li class="flex gap-3">
              <span class="text-gh-fg-muted">&minus;</span>
              <span>CI/CD and infra-as-code via Terraform and Azure DevOps; PostgreSQL workflow state</span>
            </li>
          </ul>
        </article>

        <article>
          <div class="flex flex-wrap items-baseline justify-between gap-x-4">
            <h3 class="text-base font-semibold text-gh-fg">PayPal</h3>
            <span class="text-xs text-gh-fg-muted">2018 &mdash; 2023</span>
          </div>
          <p class="mt-1 text-base font-medium text-gh-fg">Software Engineer</p>
          <p class="mt-3 text-sm leading-relaxed text-gh-fg sm:text-base">
            I built platform tooling and workflow orchestration for backend engineering teams shipping microservices on
            GCP/GKE under NIST-800-53 and PCI-DSS controls.
          </p>
          <ul class="mt-3 space-y-1.5 text-sm leading-relaxed text-gh-fg-muted sm:text-base">
            <li class="flex gap-3">
              <span class="text-gh-fg-muted">&minus;</span>
              <span
                >Platform tooling and CI/CD for 20+ backend engineers shipping microservices on GCP and GKE &mdash; Helm
                charts and release pipelines</span
              >
            </li>
            <li class="flex gap-3">
              <span class="text-gh-fg-muted">&minus;</span>
              <span>Event-driven workflow orchestration with Airflow and Composer at scale</span>
            </li>
            <li class="flex gap-3">
              <span class="text-gh-fg-muted">&minus;</span>
              <span
                >Secure data-handling per NIST-800-53 and PCI-DSS &mdash; secrets management and security controls</span
              >
            </li>
          </ul>
        </article>

        <article>
          <div class="flex flex-wrap items-baseline justify-between gap-x-4">
            <h3 class="text-base font-semibold text-gh-fg">CDW</h3>
            <span class="text-xs text-gh-fg-muted">2014 &mdash; 2018</span>
          </div>
          <p class="mt-1 text-base font-medium text-gh-fg">Software Engineer &middot; Platform Engineer</p>
          <ul class="mt-3 space-y-1.5 text-sm leading-relaxed text-gh-fg-muted sm:text-base">
            <li class="flex gap-3">
              <span class="text-gh-fg-muted">&minus;</span>
              <span>Python automation tooling for cloud migration and deployment across client engagements</span>
            </li>
            <li class="flex gap-3">
              <span class="text-gh-fg-muted">&minus;</span>
              <span>Led a team automating enterprise infrastructure provisioning and platform operations</span>
            </li>
            <li class="flex gap-3">
              <span class="text-gh-fg-muted">&minus;</span>
              <span
                >NetApp storage, VMware virtualization, FortiGate firewalls &mdash; enterprise infrastructure stack
                across client engagements</span
              >
            </li>
          </ul>
        </article>

        <article>
          <div class="flex flex-wrap items-baseline justify-between gap-x-4">
            <h3 class="text-base font-semibold text-gh-fg">Tech Data</h3>
            <span class="text-xs text-gh-fg-muted">2010 &mdash; 2014</span>
          </div>
          <p class="mt-1 text-base font-medium text-gh-fg">Systems Engineer</p>
          <ul class="mt-3 space-y-1.5 text-sm leading-relaxed text-gh-fg-muted sm:text-base">
            <li class="flex gap-3">
              <span class="text-gh-fg-muted">&minus;</span>
              <span>Automated enterprise infrastructure provisioning for large organizations</span>
            </li>
            <li class="flex gap-3">
              <span class="text-gh-fg-muted">&minus;</span>
              <span
                >NetApp storage, VMware virtualization, FortiGate firewalls &mdash; enterprise infrastructure stack</span
              >
            </li>
          </ul>
        </article>

        <article>
          <div class="flex flex-wrap items-baseline justify-between gap-x-4">
            <h3 class="text-base font-semibold text-gh-fg">TD Bank Financial Group</h3>
            <span class="text-xs text-gh-fg-muted">2003 &mdash; 2009</span>
          </div>
          <p class="mt-1 text-base font-medium text-gh-fg">Systems Engineer</p>
          <ul class="mt-3 space-y-1.5 text-sm leading-relaxed text-gh-fg-muted sm:text-base">
            <li class="flex gap-3">
              <span class="text-gh-fg-muted">&minus;</span>
              <span>Datacenter operations across Dell &amp; IBM servers and Windows Server fleets</span>
            </li>
          </ul>
        </article>
      </div>
    </section>

    <!-- Education -->
    <section class="mt-12 border-t border-gh-border pt-10">
      <h2 class="text-base font-bold uppercase tracking-[0.2em] text-gh-blue">// education</h2>
      <article class="mt-6">
        <div class="flex flex-wrap items-baseline justify-between gap-x-4">
          <h3 class="text-base font-semibold text-gh-fg">Northern Alberta Institute of Technology</h3>
          <span class="text-xs text-gh-fg-muted">2000 &mdash; 2002</span>
        </div>
        <p class="mt-1 text-sm text-gh-fg-muted">Network Engineering Technology</p>
      </article>
    </section>
  </article>

  <style is:global>
    @media print {
      html {
        font-size: 10px;
      }
      body > header,
      body > footer {
        display: none !important;
      }
      main {
        padding: 0 !important;
      }
      .resume {
        max-width: 100% !important;
        padding: 0.75in !important;
        margin: 0 !important;
      }
      body {
        background: #ffffff !important;
        color: #000000 !important;
      }
      .resume h1 {
        font-size: 1.6rem;
      }
      .resume h2 {
        font-size: 1.15rem;
      }
      .resume h3 {
        font-size: 1.3rem;
      }
      .resume article > div + p {
        font-size: 1.1rem;
      }
      .resume a {
        color: #000000 !important;
        text-decoration: none;
      }
      .resume .border-t {
        border-color: #d0d7de !important;
      }
      .resume article {
        break-inside: avoid;
      }
      .animate-on-scroll,
      .animate-hero {
        opacity: 1 !important;
        transform: none !important;
        animation: none !important;
      }
    }
  </style>
</Layout>
