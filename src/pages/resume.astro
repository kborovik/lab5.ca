---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Resume"
  schemaType="ProfilePage"
  description="Konstantin Borovik — AI Automation Engineer in Toronto, Canada. 20+ years engineering. Skills, engagements, and education."
>
  <article class="resume mx-auto max-w-3xl px-6 py-12 sm:py-16">

    <!-- Contact -->
    <header class="resume-contact">
      <h1 class="text-3xl font-bold tracking-tight text-gh-fg sm:text-4xl">
        Resume
      </h1>
      <p class="mt-4 text-base font-semibold text-gh-fg">
        Konstantin Borovik
      </p>
      <p class="mt-1 text-sm text-gh-fg-muted">
        AI Automation Engineer &middot; 20+ years engineering
      </p>
      <address class="mt-1 text-sm not-italic text-gh-fg-muted">
        Toronto, Ontario, Canada
      </address>

      <ul class="resume-links mt-5 flex flex-wrap gap-x-5 gap-y-2 text-sm text-gh-fg-muted">
        <li>
          <a
            href="https://www.linkedin.com/in/kborovik"
            target="_blank"
            rel="noopener noreferrer"
            class="hover:text-gh-blue"
          >linkedin.com/in/kborovik</a>
        </li>
        <li>
          <a
            href="https://github.com/kborovik"
            target="_blank"
            rel="noopener noreferrer"
            class="hover:text-gh-blue"
          >github.com/kborovik</a>
        </li>
        <li>
          <a
            href="https://x.com/kborovik"
            target="_blank"
            rel="noopener noreferrer"
            class="hover:text-gh-blue"
          >x.com/kborovik</a>
        </li>
        <li>
          <a
            href="https://bsky.app/profile/lab5.ca"
            target="_blank"
            rel="noopener noreferrer"
            class="hover:text-gh-blue"
          >bsky.app/profile/lab5.ca</a>
        </li>
        <li>
          <a
            href="https://calendar.app.google/cYM3H3TsHsequR587"
            target="_blank"
            rel="noopener noreferrer"
            class="hover:text-gh-blue"
          >book a call</a>
        </li>
        <li>
          <a
            href="mailto:kb@lab5.ca"
            class="hover:text-gh-blue"
          >kb@lab5.ca</a>
        </li>
      </ul>
    </header>

    <!-- Skills -->
    <section class="mt-12 border-t border-gh-border pt-10">
      <h2 class="text-sm font-bold uppercase tracking-[0.2em] text-gh-blue">
        // skills
      </h2>

      <div class="mt-8 space-y-8 text-sm leading-relaxed text-gh-fg-muted sm:text-base">
        <div>
          <h3 class="text-base font-semibold text-gh-fg">
            AI automation
          </h3>
          <ul class="mt-3 space-y-1.5">
            <li class="flex gap-3">
              <span class="text-gh-fg-muted">&minus;</span>
              <span>ERP integration &mdash; NetSuite, QuickBooks, Xero, Salesforce, HubSpot; idempotent state machines triggered on upstream events</span>
            </li>
            <li class="flex gap-3">
              <span class="text-gh-fg-muted">&minus;</span>
              <span>document workflow &mdash; OCR + LLM structured extraction, schema validation w/ confidence scoring, routing to systems of record</span>
            </li>
            <li class="flex gap-3">
              <span class="text-gh-fg-muted">&minus;</span>
              <span>AI email &amp; communication &mdash; Gmail API triage, retrieval over internal knowledge bases (RAG), drafted replies</span>
            </li>
            <li class="flex gap-3">
              <span class="text-gh-fg-muted">&minus;</span>
              <span>data &amp; reporting &mdash; scheduled aggregation across databases, sheets, and APIs; LLM narration w/ citations</span>
            </li>
          </ul>
        </div>

        <div>
          <h3 class="text-base font-semibold text-gh-fg">
            Stack
          </h3>
          <ul class="mt-3 space-y-1.5">
            <li class="flex gap-3">
              <span class="text-gh-fg-muted">&minus;</span>
              <span>Python, TypeScript</span>
            </li>
            <li class="flex gap-3">
              <span class="text-gh-fg-muted">&minus;</span>
              <span>Pydantic AI, LLM agents and agentic workflows, retrieval-augmented generation, structured extraction, MCP</span>
            </li>
            <li class="flex gap-3">
              <span class="text-gh-fg-muted">&minus;</span>
              <span>Astro, Cloudflare Workers</span>
            </li>
            <li class="flex gap-3">
              <span class="text-gh-fg-muted">&minus;</span>
              <span>PostgreSQL, Pub/Sub, event-driven architecture, idempotent processing, DLQs</span>
            </li>
            <li class="flex gap-3">
              <span class="text-gh-fg-muted">&minus;</span>
              <span>GCP &mdash; Cloud Run, Cloud Functions, BigQuery, Vertex AI, Cloud SQL, IAM</span>
            </li>
            <li class="flex gap-3">
              <span class="text-gh-fg-muted">&minus;</span>
              <span>CI/CD and infra-as-code &mdash; Terraform, GitHub Actions, Azure DevOps, Docker, Kubernetes (GKE)</span>
            </li>
          </ul>
        </div>
      </div>
    </section>

    <!-- Engagements -->
    <section class="mt-12 border-t border-gh-border pt-10">
      <h2 class="text-sm font-bold uppercase tracking-[0.2em] text-gh-blue">
        // engagements
      </h2>

      <div class="mt-8 space-y-10">

        <article>
          <div class="flex flex-wrap items-baseline justify-between gap-x-4">
            <h3 class="text-base font-semibold text-gh-fg">
              lab5.ca
            </h3>
            <span class="text-xs text-gh-fg-muted">2026 &mdash; present</span>
          </div>
          <p class="mt-1 text-sm text-gh-fg-muted">
            Independent contractor &middot; AI Automation Engineer
          </p>
          <p class="mt-3 text-sm leading-relaxed text-gh-fg sm:text-base">
            I run an independent practice building AI automation for business operations &mdash; ERP integration, document workflow, AI email, and reporting. MailPilot is my proof-of-capability project (open source).
          </p>
          <ul class="mt-3 space-y-1.5 text-sm leading-relaxed text-gh-fg-muted sm:text-base">
            <li class="flex gap-3">
              <span class="text-gh-fg-muted">&minus;</span>
              <span>MailPilot &mdash; AI email automation, end-to-end (Python, PostgreSQL, Pub/Sub, Cloud Run, GCP)</span>
            </li>
            <li class="flex gap-3">
              <span class="text-gh-fg-muted">&minus;</span>
              <span>Pydantic AI agents, structured-extraction pipelines, idempotent state machines</span>
            </li>
          </ul>
        </article>

        <article>
          <div class="flex flex-wrap items-baseline justify-between gap-x-4">
            <h3 class="text-base font-semibold text-gh-fg">
              Colliers International
            </h3>
            <span class="text-xs text-gh-fg-muted">2023 &mdash; 2025</span>
          </div>
          <p class="mt-1 text-sm text-gh-fg-muted">
            Senior Software Engineer
          </p>
          <p class="mt-3 text-sm leading-relaxed text-gh-fg sm:text-base">
            I replaced manual data-processing workflows with serverless Python on GCP and Airflow ETL pipelines, backed by PostgreSQL for workflow state.
          </p>
          <ul class="mt-3 space-y-1.5 text-sm leading-relaxed text-gh-fg-muted sm:text-base">
            <li class="flex gap-3">
              <span class="text-gh-fg-muted">&minus;</span>
              <span>Event-driven Python services on Cloud Run and Cloud Functions, replacing manual data-processing workflows</span>
            </li>
            <li class="flex gap-3">
              <span class="text-gh-fg-muted">&minus;</span>
              <span>Airflow ETL orchestration; idempotent self-recovering pipelines replacing manual data transfers</span>
            </li>
            <li class="flex gap-3">
              <span class="text-gh-fg-muted">&minus;</span>
              <span>CI/CD and infra-as-code via Terraform and Azure DevOps; PostgreSQL workflow state</span>
            </li>
          </ul>
        </article>

        <article>
          <div class="flex flex-wrap items-baseline justify-between gap-x-4">
            <h3 class="text-base font-semibold text-gh-fg">
              PayPal
            </h3>
            <span class="text-xs text-gh-fg-muted">2018 &mdash; 2023</span>
          </div>
          <p class="mt-1 text-sm text-gh-fg-muted">
            Software Engineer
          </p>
          <p class="mt-3 text-sm leading-relaxed text-gh-fg sm:text-base">
            I built platform tooling and workflow orchestration for backend engineering teams shipping microservices on GCP/GKE under NIST-800-53 and PCI-DSS controls.
          </p>
          <ul class="mt-3 space-y-1.5 text-sm leading-relaxed text-gh-fg-muted sm:text-base">
            <li class="flex gap-3">
              <span class="text-gh-fg-muted">&minus;</span>
              <span>Platform tooling and CI/CD for 20+ backend engineers shipping microservices on GCP and GKE</span>
            </li>
            <li class="flex gap-3">
              <span class="text-gh-fg-muted">&minus;</span>
              <span>Event-driven workflow orchestration with Airflow and Composer at scale</span>
            </li>
            <li class="flex gap-3">
              <span class="text-gh-fg-muted">&minus;</span>
              <span>Secure data-handling per NIST-800-53 and PCI-DSS &mdash; secrets management and security controls</span>
            </li>
          </ul>
        </article>

        <article>
          <div class="flex flex-wrap items-baseline justify-between gap-x-4">
            <h3 class="text-base font-semibold text-gh-fg">
              CDW
            </h3>
            <span class="text-xs text-gh-fg-muted">2014 &mdash; 2018</span>
          </div>
          <p class="mt-1 text-sm text-gh-fg-muted">
            Software Engineer &middot; Platform Engineer
          </p>
          <ul class="mt-3 space-y-1.5 text-sm leading-relaxed text-gh-fg-muted sm:text-base">
            <li class="flex gap-3">
              <span class="text-gh-fg-muted">&minus;</span>
              <span>Python automation tooling for cloud migration and deployment across client engagements</span>
            </li>
            <li class="flex gap-3">
              <span class="text-gh-fg-muted">&minus;</span>
              <span>Led a team automating enterprise infrastructure provisioning and platform operations</span>
            </li>
          </ul>
        </article>

        <article>
          <div class="flex flex-wrap items-baseline justify-between gap-x-4">
            <h3 class="text-base font-semibold text-gh-fg">
              Tech Data
            </h3>
            <span class="text-xs text-gh-fg-muted">2010 &mdash; 2014</span>
          </div>
          <p class="mt-1 text-sm text-gh-fg-muted">
            Systems Engineer
          </p>
          <ul class="mt-3 space-y-1.5 text-sm leading-relaxed text-gh-fg-muted sm:text-base">
            <li class="flex gap-3">
              <span class="text-gh-fg-muted">&minus;</span>
              <span>Automated enterprise infrastructure provisioning for large organizations</span>
            </li>
          </ul>
        </article>

        <article>
          <div class="flex flex-wrap items-baseline justify-between gap-x-4">
            <h3 class="text-base font-semibold text-gh-fg">
              TD Bank Financial Group
            </h3>
            <span class="text-xs text-gh-fg-muted">2003 &mdash; 2009</span>
          </div>
          <p class="mt-1 text-sm text-gh-fg-muted">
            Systems Engineer
          </p>
          <ul class="mt-3 space-y-1.5 text-sm leading-relaxed text-gh-fg-muted sm:text-base">
            <li class="flex gap-3">
              <span class="text-gh-fg-muted">&minus;</span>
              <span>Data center migration and large-scale virtualization rollouts (200+ VMs)</span>
            </li>
          </ul>
        </article>

      </div>
    </section>

    <!-- Education -->
    <section class="mt-12 border-t border-gh-border pt-10">
      <h2 class="text-sm font-bold uppercase tracking-[0.2em] text-gh-blue">
        // education
      </h2>
      <article class="mt-6">
        <div class="flex flex-wrap items-baseline justify-between gap-x-4">
          <h3 class="text-base font-semibold text-gh-fg">
            Northern Alberta Institute of Technology
          </h3>
          <span class="text-xs text-gh-fg-muted">2000 &mdash; 2002</span>
        </div>
        <p class="mt-1 text-sm text-gh-fg-muted">
          Network Engineering Technology
        </p>
      </article>
    </section>

  </article>

  <style is:global>
    @media print {
      header,
      footer {
        display: none !important;
      }
      main {
        padding: 0 !important;
      }
      .resume {
        max-width: 100% !important;
        padding: 0.5in !important;
        margin: 0 !important;
      }
      body {
        background: #ffffff !important;
        color: #000000 !important;
        font-size: 10.5pt;
      }
      .resume h1 {
        font-size: 18pt;
      }
      .resume h2 {
        font-size: 10pt;
      }
      .resume h3 {
        font-size: 11pt;
      }
      .resume a {
        color: #000000 !important;
        text-decoration: none;
      }
      .resume .border-t {
        border-color: #d0d7de !important;
      }
      .resume article {
        break-inside: avoid;
      }
      .animate-on-scroll,
      .animate-hero {
        opacity: 1 !important;
        transform: none !important;
        animation: none !important;
      }
    }
  </style>
</Layout>
