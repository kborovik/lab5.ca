---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import headshot from '../assets/konstantin-borovik-headshot.jpg';
---

<Layout
  description="Konstantin Borovik — Software Developer | DevOps Engineer based in Toronto, Canada. Cloud infrastructure, AI agents for business workflows, web development. 20+ years engineering."
>
  <!-- (a) hero -->
  <section class="mx-auto max-w-5xl px-6 pt-16 pb-12 sm:pt-20 sm:pb-14 font-mono">
    <div class="grid gap-10 sm:grid-cols-3 sm:items-center">

      <div class="sm:col-span-2">
        <h1 class="animate-hero text-3xl font-bold tracking-tight text-gh-fg sm:text-4xl" style="animation-delay: 0ms;">
          Konstantin Borovik
        </h1>
        <p class="animate-hero mt-3 text-base font-semibold text-gh-fg sm:text-lg" style="animation-delay: 80ms;">
          Software Developer | DevOps Engineer
        </p>
        <address class="animate-hero mt-4 text-sm not-italic text-gh-fg-muted" style="animation-delay: 160ms;">
          Toronto, Ontario, Canada
        </address>
      </div>

      <Image
        src={headshot}
        alt="Konstantin Borovik"
        width={400}
        height={400}
        class="animate-hero mx-auto h-40 w-40 rounded-lg border border-gh-border object-cover object-top sm:mx-0 sm:h-48 sm:w-48"
        style="animation-delay: 320ms;"
      />

    </div>
  </section>

  <!-- (b) // what I do — 3-tile services grid per V2 -->
  <section class="mx-auto max-w-5xl px-6 pb-12 sm:pb-14 font-mono">
    <h2 class="animate-on-scroll text-center text-base font-bold uppercase tracking-[0.2em] text-gh-blue" style="transition-delay: 0ms;">
      // what I do
    </h2>

    <div class="mt-12 grid gap-10 sm:grid-cols-3 sm:gap-x-12 sm:gap-y-14">

      <a href="/projects#gcp-devops" class="animate-on-scroll group block" style="transition-delay: 0ms;">
        <div class="flex items-baseline gap-2 text-xs text-gh-fg-muted">
          <span>01</span>
          <span class="h-px flex-1 bg-gh-border"></span>
        </div>
        <h3 class="mt-3 text-base font-semibold text-gh-fg group-hover:text-gh-green transition-colors">
          Cloud Infrastructure
        </h3>
        <p class="mt-2 text-sm leading-relaxed text-gh-fg-muted">
          <strong class="font-semibold text-gh-fg">Google Cloud</strong> and <strong class="font-semibold text-gh-fg">Azure</strong> platforms shipped as infrastructure-as-code on <strong class="font-semibold text-gh-fg">GitHub</strong>. Provisioned, observable, repeatable.
        </p>
      </a>

      <a href="/projects#mailpilot" class="animate-on-scroll group block" style="transition-delay: 80ms;">
        <div class="flex items-baseline gap-2 text-xs text-gh-fg-muted">
          <span>02</span>
          <span class="h-px flex-1 bg-gh-border"></span>
        </div>
        <h3 class="mt-3 text-base font-semibold text-gh-fg group-hover:text-gh-green transition-colors">
          AI Agents for Business Workflows
        </h3>
        <p class="mt-2 text-sm leading-relaxed text-gh-fg-muted">
          <strong class="font-semibold text-gh-fg">Pydantic AI</strong> agents on the <strong class="font-semibold text-gh-fg">Claude API</strong>, wired to real systems &mdash; email triage, structured extraction, retrieval over internal knowledge bases. MailPilot is the live reference.
        </p>
      </a>

      <a href="/projects#lab5" class="animate-on-scroll group block" style="transition-delay: 160ms;">
        <div class="flex items-baseline gap-2 text-xs text-gh-fg-muted">
          <span>03</span>
          <span class="h-px flex-1 bg-gh-border"></span>
        </div>
        <h3 class="mt-3 text-base font-semibold text-gh-fg group-hover:text-gh-green transition-colors">
          Web Development
        </h3>
        <p class="mt-2 text-sm leading-relaxed text-gh-fg-muted">
          <strong class="font-semibold text-gh-fg">Astro</strong> static sites on Cloudflare Workers. This site is the reference build &mdash; spec-driven, deploy on push.
        </p>
      </a>

    </div>
  </section>

  <!-- (c) // tech stack — 4 H3 subgroups (high-level summary; depth on /resume) -->
  <section class="mx-auto max-w-5xl px-6 pb-12 sm:pb-14 font-mono">
    <h2 class="animate-on-scroll text-base font-bold uppercase tracking-[0.2em] text-gh-blue" style="transition-delay: 0ms;">
      // tech stack
    </h2>

    <div class="mt-10 grid gap-8 sm:grid-cols-2 sm:gap-x-12 sm:gap-y-10">

      <div class="animate-on-scroll" style="transition-delay: 0ms;">
        <h3 class="text-base font-semibold text-gh-fg">Python &amp; TypeScript</h3>
        <p class="mt-2 text-sm leading-relaxed text-gh-fg-muted">
          Python &middot; TypeScript &middot; Bash &middot; SQL
        </p>
      </div>

      <div class="animate-on-scroll" style="transition-delay: 80ms;">
        <h3 class="text-base font-semibold text-gh-fg">Google Cloud &amp; Azure</h3>
        <p class="mt-2 text-sm leading-relaxed text-gh-fg-muted">
          Cloud Run &middot; BigQuery &middot; Vertex AI &middot; App Service &middot; Functions &middot; Key Vault
        </p>
      </div>

      <div class="animate-on-scroll" style="transition-delay: 160ms;">
        <h3 class="text-base font-semibold text-gh-fg">AI Automation</h3>
        <p class="mt-2 text-sm leading-relaxed text-gh-fg-muted">
          Pydantic AI &middot; Claude API &middot; LLM agents &middot; RAG &middot; structured extraction &middot; MCP
        </p>
      </div>

      <div class="animate-on-scroll" style="transition-delay: 240ms;">
        <h3 class="text-base font-semibold text-gh-fg">CI/CD &amp; Terraform</h3>
        <p class="mt-2 text-sm leading-relaxed text-gh-fg-muted">
          Terraform &middot; Ansible &middot; GitHub Actions &middot; Azure DevOps &middot; Docker &middot; Kubernetes
        </p>
      </div>

    </div>
  </section>

  <!-- (d) // claims — falsifiable facts -->
  <section class="mx-auto max-w-5xl px-6 pb-12 sm:pb-14 font-mono">
    <h2 class="animate-on-scroll text-base font-bold uppercase tracking-[0.2em] text-gh-blue" style="transition-delay: 0ms;">
      // claims
    </h2>
    <ul class="animate-on-scroll mt-6 space-y-2 text-sm leading-relaxed text-gh-fg-muted sm:text-base" style="transition-delay: 80ms;">
      <li class="flex gap-3">
        <span class="text-gh-fg-muted">&minus;</span>
        <span>20+ years shipping production systems &mdash; data centers, global payments, commercial real estate, AI automation</span>
      </li>
      <li class="flex gap-3">
        <span class="text-gh-fg-muted">&minus;</span>
        <span>Python and TypeScript daily; production LLM agents on Pydantic AI and the Claude API</span>
      </li>
      <li class="flex gap-3">
        <span class="text-gh-fg-muted">&minus;</span>
        <span>Google Cloud infrastructure shipped with Terraform, GitHub Actions, and Cloud Run &mdash; one engineer, end-to-end</span>
      </li>
      <li class="flex gap-3">
        <span class="text-gh-fg-muted">&minus;</span>
        <span>MailPilot built end-to-end: Pydantic AI agent, GCP backend, IaC, deploy &mdash; live at <span class="font-bold text-gh-fg">demo@lab5.ca</span></span>
      </li>
      <li class="flex gap-3">
        <span class="text-gh-fg-muted">&minus;</span>
        <span>Current focus: cloud infrastructure, AI agents for business workflows, and web development</span>
      </li>
    </ul>
  </section>

  <!-- (e) // proof — link list -->
  <section class="mx-auto max-w-5xl px-6 pb-12 sm:pb-14 font-mono">
    <h2 class="animate-on-scroll text-base font-bold uppercase tracking-[0.2em] text-gh-blue" style="transition-delay: 0ms;">
      // proof
    </h2>
    <div class="animate-on-scroll mt-6 flex flex-wrap gap-3" style="transition-delay: 80ms;">
      <a
        href="/projects"
        class="inline-flex items-center gap-2 rounded-lg border border-gh-border bg-white px-4 py-2 text-sm font-bold text-gh-fg transition-colors hover:bg-gh-canvas-subtle"
      >
        <svg class="h-4 w-4 text-gh-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
        </svg>
        projects
      </a>
      <a
        href="/blog"
        class="inline-flex items-center gap-2 rounded-lg border border-gh-border bg-white px-4 py-2 text-sm font-bold text-gh-fg transition-colors hover:bg-gh-canvas-subtle"
      >
        <svg class="h-4 w-4 text-gh-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" />
        </svg>
        blog
      </a>
      <a
        href="/proof"
        class="inline-flex items-center gap-2 rounded-lg border border-gh-border bg-white px-4 py-2 text-sm font-bold text-gh-fg transition-colors hover:bg-gh-canvas-subtle"
      >
        <svg class="h-4 w-4 text-gh-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
        </svg>
        MailPilot demo
      </a>
      <a
        href="https://www.linkedin.com/in/kborovik"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 rounded-lg border border-gh-border bg-white px-4 py-2 text-sm font-bold text-gh-fg transition-colors hover:bg-gh-canvas-subtle"
      >
        <svg class="h-4 w-4 text-gh-blue" fill="currentColor" viewBox="0 0 24 24"><path d="M20.5 2h-17A1.5 1.5 0 002 3.5v17A1.5 1.5 0 003.5 22h17a1.5 1.5 0 001.5-1.5v-17A1.5 1.5 0 0020.5 2zM8 19H5v-9h3zM6.5 8.25A1.75 1.75 0 118.3 6.5a1.78 1.78 0 01-1.8 1.75zM19 19h-3v-4.74c0-1.42-.6-1.93-1.38-1.93A1.74 1.74 0 0013 14.19a.66.66 0 000 .14V19h-3v-9h2.9v1.3a3.11 3.11 0 012.7-1.4c1.55 0 3.36.86 3.36 3.66z" /></svg>
        linkedin
      </a>
      <a
        href="https://github.com/kborovik"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 rounded-lg border border-gh-border bg-white px-4 py-2 text-sm font-bold text-gh-fg transition-colors hover:bg-gh-canvas-subtle"
      >
        <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/></svg>
        github
      </a>
    </div>
  </section>

  <!-- (f) // résumé — single bordered button -->
  <section class="mx-auto max-w-5xl px-6 pb-20 sm:pb-24 font-mono">
    <h2 class="animate-on-scroll text-base font-bold uppercase tracking-[0.2em] text-gh-blue" style="transition-delay: 0ms;">
      // résumé
    </h2>
    <div class="animate-on-scroll mt-6" style="transition-delay: 80ms;">
      <a
        href="/resume"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 rounded-lg border border-gh-border bg-white px-4 py-2 text-sm font-bold text-gh-fg transition-colors hover:bg-gh-canvas-subtle"
      >
        <svg class="h-4 w-4 text-gh-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
        </svg>
        Download résumé (PDF)
      </a>
    </div>
  </section>
</Layout>
