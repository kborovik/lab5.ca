---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <!-- Hero -->
  <section class="mx-auto max-w-5xl px-6 py-24 sm:py-32">
    <div class="flex flex-col items-center gap-12 lg:flex-row lg:items-center lg:gap-16">

      <!-- Left: copy -->
      <div class="flex-1 text-center lg:text-left">
        <div class="mb-6 inline-flex items-center gap-2 rounded-full bg-gh-green-muted px-4 py-1.5 text-xs font-semibold uppercase tracking-widest text-gh-green">
          Tech Lead for Business Modernization
        </div>
        <h1 class="text-4xl font-bold tracking-tight text-gh-fg sm:text-6xl">
          I modernize business operations with Google Cloud
        </h1>
        <p class="mx-auto mt-6 max-w-xl text-lg text-gh-fg-muted lg:mx-0">
          I help 20–100 person companies connect their ERP, CRM, email,
          and documents on Google Cloud — so your operations run faster,
          your team works on what matters, and your technology grows
          with your company.
        </p>
        <div class="mt-10 flex flex-col items-center gap-4 sm:flex-row sm:justify-center lg:justify-start">
          <a
            href="https://calendar.app.google/cYM3H3TsHsequR587"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 rounded-lg bg-gh-green px-6 py-3 text-base font-semibold text-white transition-colors hover:bg-gh-green-hover"
          >
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor"><path d="M19 4h-1V2h-2v2H8V2H6v2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 16H5V10h14v10zm0-12H5V6h14v2zM7 12h5v5H7v-5z"/></svg>
            Book a Call
          </a>
          <a
            href="/demo"
            class="inline-flex items-center gap-2 rounded-lg border border-gh-border bg-white px-6 py-3 text-base font-semibold text-gh-fg transition-colors hover:border-gh-fg hover:bg-gh-canvas-subtle"
          >
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" /></svg>
            See a Live Demo
          </a>
        </div>
      </div>

      <!-- Right: what changes card (hidden on mobile) -->
      <div class="hidden lg:block lg:w-[340px] xl:w-[380px]">
        <div class="rounded-2xl border border-gh-border bg-white shadow-sm overflow-hidden">
          <div class="border-b border-gh-border bg-gh-canvas-subtle px-4 py-3">
            <span class="text-xs font-semibold text-gh-fg-subtle uppercase tracking-wider">What Changes</span>
          </div>
          <div class="divide-y divide-gh-border">
            <div class="p-4 flex items-center gap-3">
              <div class="flex h-9 w-9 items-center justify-center rounded-lg bg-gh-green/10">
                <svg class="h-5 w-5 text-gh-green" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z" />
                </svg>
              </div>
              <div>
                <p class="text-sm font-semibold text-gh-fg">Manual workflows become automated</p>
                <p class="text-xs text-gh-fg-muted">Your team stops re-entering the same data</p>
              </div>
            </div>
            <div class="p-4 flex items-center gap-3">
              <div class="flex h-9 w-9 items-center justify-center rounded-lg bg-gh-blue/10">
                <svg class="h-5 w-5 text-gh-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z" />
                </svg>
              </div>
              <div>
                <p class="text-sm font-semibold text-gh-fg">Systems move to Google Cloud</p>
                <p class="text-xs text-gh-fg-muted">Reliable infrastructure without a heavy ops footprint</p>
              </div>
            </div>
            <div class="p-4 flex items-center gap-3">
              <div class="flex h-9 w-9 items-center justify-center rounded-lg bg-gh-green/10">
                <svg class="h-5 w-5 text-gh-green" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4" />
                </svg>
              </div>
              <div>
                <p class="text-sm font-semibold text-gh-fg">Disconnected tools get integrated</p>
                <p class="text-xs text-gh-fg-muted">Orders, invoices, and messages stay in sync</p>
              </div>
            </div>
            <div class="p-4 flex items-center gap-3">
              <div class="flex h-9 w-9 items-center justify-center rounded-lg bg-gh-blue/10">
                <svg class="h-5 w-5 text-gh-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
              </div>
              <div>
                <p class="text-sm font-semibold text-gh-fg">Your team gets technical leadership</p>
                <p class="text-xs text-gh-fg-muted">A tech lead who writes code every day</p>
              </div>
            </div>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- How I Help -->
  <section class="border-t border-gh-border bg-gh-canvas-subtle py-24">
    <div class="mx-auto max-w-5xl px-6">
      <p class="text-sm font-semibold uppercase tracking-widest text-gh-green">How I Help</p>
      <h2 class="mt-2 text-3xl font-bold tracking-tight text-gh-fg sm:text-4xl">
        From disconnected systems to connected operations
      </h2>
      <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">

        <!-- Card 1: Systems Integration -->
        <div class="group rounded-2xl border border-gh-border bg-white p-8 transition-all duration-200 hover:border-gh-green/30 hover:shadow-[0_4px_16px_rgba(0,0,0,0.06)]">
          <div class="mb-4 flex items-start gap-3">
            <div class="flex-shrink-0">
              <svg class="h-7 w-7 text-gh-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4" />
              </svg>
            </div>
            <div class="text-3xl font-bold text-gh-border leading-none pt-0.5">01</div>
          </div>
          <h3 class="text-base font-semibold text-gh-fg">Systems Integration</h3>
          <p class="mt-3 text-sm leading-relaxed text-gh-fg-muted">
            Connect ERP, CRM, email, and documents into unified workflows
            on Google Cloud &mdash; your systems talk to each other automatically.
          </p>
          <a href="/expertise#integration" class="mt-6 inline-block text-sm font-semibold text-gh-green transition-colors hover:text-gh-green-hover">
            Learn more &rarr;
          </a>
        </div>

        <!-- Card 2: Custom Software Development -->
        <div class="group rounded-2xl border border-gh-border bg-white p-8 transition-all duration-200 hover:border-gh-green/30 hover:shadow-[0_4px_16px_rgba(0,0,0,0.06)]">
          <div class="mb-4 flex items-start gap-3">
            <div class="flex-shrink-0">
              <svg class="h-7 w-7 text-gh-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
              </svg>
            </div>
            <div class="text-3xl font-bold text-gh-border leading-none pt-0.5">02</div>
          </div>
          <h3 class="text-base font-semibold text-gh-fg">Custom Software Development</h3>
          <p class="mt-3 text-sm leading-relaxed text-gh-fg-muted">
            End-to-end product development on Google Cloud &mdash; backend, frontend,
            infrastructure, and deployment from one person.
          </p>
          <a href="/expertise#development" class="mt-6 inline-block text-sm font-semibold text-gh-green transition-colors hover:text-gh-green-hover">
            Learn more &rarr;
          </a>
        </div>

        <!-- Card 3: AI-Powered Automation -->
        <div class="group rounded-2xl border border-gh-border bg-white p-8 transition-all duration-200 hover:border-gh-green/30 hover:shadow-[0_4px_16px_rgba(0,0,0,0.06)]">
          <div class="mb-4 flex items-start gap-3">
            <div class="flex-shrink-0">
              <svg class="h-7 w-7 text-gh-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z" />
              </svg>
            </div>
            <div class="text-3xl font-bold text-gh-border leading-none pt-0.5">03</div>
          </div>
          <h3 class="text-base font-semibold text-gh-fg">AI-Powered Automation</h3>
          <p class="mt-3 text-sm leading-relaxed text-gh-fg-muted">
            Production AI systems that handle routine work &mdash;
            document processing, email agents, and knowledge base search.
          </p>
          <a href="/expertise#ai" class="mt-6 inline-block text-sm font-semibold text-gh-green transition-colors hover:text-gh-green-hover">
            Learn more &rarr;
          </a>
        </div>

        <!-- Card 4: Technical Leadership -->
        <div class="group rounded-2xl border border-gh-border bg-white p-8 transition-all duration-200 hover:border-gh-green/30 hover:shadow-[0_4px_16px_rgba(0,0,0,0.06)]">
          <div class="mb-4 flex items-start gap-3">
            <div class="flex-shrink-0">
              <svg class="h-7 w-7 text-gh-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <div class="text-3xl font-bold text-gh-border leading-none pt-0.5">04</div>
          </div>
          <h3 class="text-base font-semibold text-gh-fg">Technical Leadership</h3>
          <p class="mt-3 text-sm leading-relaxed text-gh-fg-muted">
            Set technical direction, build engineering teams,
            and create a culture where teams ship confidently.
          </p>
          <a href="/expertise#leadership" class="mt-6 inline-block text-sm font-semibold text-gh-green transition-colors hover:text-gh-green-hover">
            Learn more &rarr;
          </a>
        </div>

      </div>
    </div>
  </section>

  <!-- Featured Project: MailPilot -->
  <section class="border-t border-gh-border bg-gh-canvas-subtle py-20">
    <div class="mx-auto max-w-5xl px-6">
      <p class="text-sm font-semibold uppercase tracking-widest text-gh-green">Featured Project</p>
      <h2 class="mt-2 text-3xl font-bold tracking-tight text-gh-fg sm:text-4xl">
        MailPilot — AI Email Automation Platform
      </h2>
      <p class="mt-3 max-w-2xl text-gh-fg-muted">
        A production AI agent I designed and built end-to-end on Google Cloud.
        Send it an email and see what I can build for your business.
      </p>

      <div class="mt-10 grid gap-8 lg:grid-cols-2">
        <!-- Left: technical details -->
        <div>
          <h3 class="text-base font-semibold text-gh-fg">Architecture & Stack</h3>
          <div class="mt-4 space-y-3">
            <div class="flex items-start gap-3">
              <svg class="mt-0.5 h-5 w-5 flex-shrink-0 text-gh-green" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <p class="text-sm text-gh-fg-muted"><span class="font-medium text-gh-fg">Backend:</span> Python, Google Cloud Functions, Cloud Pub/Sub, Gmail push notifications</p>
            </div>
            <div class="flex items-start gap-3">
              <svg class="mt-0.5 h-5 w-5 flex-shrink-0 text-gh-green" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <p class="text-sm text-gh-fg-muted"><span class="font-medium text-gh-fg">AI Layer:</span> LLM integration, RAG pipeline, Google Drive knowledge base</p>
            </div>
            <div class="flex items-start gap-3">
              <svg class="mt-0.5 h-5 w-5 flex-shrink-0 text-gh-green" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <p class="text-sm text-gh-fg-muted"><span class="font-medium text-gh-fg">Frontend:</span> Astro, Tailwind CSS, Cloudflare Workers edge deployment</p>
            </div>
            <div class="flex items-start gap-3">
              <svg class="mt-0.5 h-5 w-5 flex-shrink-0 text-gh-green" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <p class="text-sm text-gh-fg-muted"><span class="font-medium text-gh-fg">Infrastructure:</span> Terraform IaC, GitHub Actions CI/CD, Google Workspace API</p>
            </div>
          </div>
          <a href="/demo" class="mt-6 inline-block text-sm font-semibold text-gh-green transition-colors hover:text-gh-green-hover">
            See the full portfolio →
          </a>
        </div>

        <!-- Right: live demo callout -->
        <div class="rounded-2xl border border-gh-border bg-white p-8">
          <h3 class="text-base font-semibold text-gh-fg">Try it yourself</h3>
          <p class="mt-2 text-sm text-gh-fg-muted">
            This is a live AI agent responding to real emails in real time.
            Send it a question and watch it work.
          </p>
          <div class="mt-6 inline-flex items-center gap-3 rounded-xl border border-gh-border bg-gh-canvas-subtle px-5 py-3 font-mono text-sm text-gh-fg">
            <svg class="h-4 w-4 text-gh-fg-subtle flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            <span>demo@lab5.ca</span>
            <button
              id="copy-email-btn"
              aria-label="Copy email address"
              class="flex items-center gap-1.5 rounded-md border border-gh-border bg-white px-2.5 py-1 text-xs font-semibold text-gh-fg-muted transition-colors hover:text-gh-fg cursor-pointer"
            >
              <svg id="copy-icon" class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
              </svg>
              <span id="copy-label">Copy</span>
            </button>
          </div>
          <div class="mt-4">
            <a
              href="mailto:demo@lab5.ca"
              class="inline-flex items-center gap-2 rounded-lg bg-gh-green px-5 py-2.5 text-sm font-semibold text-white transition-colors hover:bg-gh-green-hover"
            >
              Send an email →
            </a>
          </div>
          <p class="mt-3 text-xs text-gh-fg-subtle">Reply within 60 seconds. No signup required.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-24">
    <div class="mx-auto max-w-3xl px-6 text-center">
      <h2 class="text-3xl font-bold tracking-tight text-gh-fg sm:text-4xl">
        Ready to modernize?
      </h2>
      <p class="mx-auto mt-4 max-w-xl text-lg text-gh-fg-muted">
        I connect your business systems to Google Cloud — so your
        operations run faster, your team works on what matters,
        and your technology grows with your company.
      </p>
      <div class="mt-8 flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
        <a
          href="https://calendar.app.google/cYM3H3TsHsequR587"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-lg bg-gh-green px-6 py-3 text-base font-semibold text-white transition-colors hover:bg-gh-green-hover"
        >
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor"><path d="M19 4h-1V2h-2v2H8V2H6v2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.89 2-2V6c0-1.1-.9-2-2-2zm0 16H5V10h14v10zm0-12H5V6h14v2zM7 12h5v5H7v-5z"/></svg>
          Book a Call
        </a>
        <a
          href="https://www.linkedin.com/in/kborovik"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-lg bg-gh-blue px-6 py-3 text-base font-semibold text-white transition-colors hover:bg-gh-blue-hover"
        >
          <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.5 2h-17A1.5 1.5 0 002 3.5v17A1.5 1.5 0 003.5 22h17a1.5 1.5 0 001.5-1.5v-17A1.5 1.5 0 0020.5 2zM8 19H5v-9h3zM6.5 8.25A1.75 1.75 0 118.3 6.5a1.78 1.78 0 01-1.8 1.75zM19 19h-3v-4.74c0-1.42-.6-1.93-1.38-1.93A1.74 1.74 0 0013 14.19a.66.66 0 000 .14V19h-3v-9h2.9v1.3a3.11 3.11 0 012.7-1.4c1.55 0 3.36.86 3.36 3.66z" /></svg>
          LinkedIn
        </a>
      </div>
    </div>
  </section>

  <script>
    const btn = document.getElementById('copy-email-btn');
    const label = document.getElementById('copy-label');
    const icon = document.getElementById('copy-icon');

    btn?.addEventListener('click', () => {
      navigator.clipboard.writeText('demo@lab5.ca').then(() => {
        if (label) label.textContent = '✓ Copied';
        if (icon) icon.style.display = 'none';
        setTimeout(() => {
          if (label) label.textContent = 'Copy';
          if (icon) icon.style.display = '';
        }, 2000);
      });
    });
  </script>
</Layout>
