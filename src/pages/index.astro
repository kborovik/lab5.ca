---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <!-- Hero — all mono, terminal/docs aesthetic -->
  <section class="mx-auto max-w-4xl px-6 pt-16 pb-10 sm:pt-20 sm:pb-12 text-center font-mono">
    <p class="animate-hero text-sm font-bold uppercase tracking-[0.2em] text-gh-blue" style="animation-delay: 0ms;">
      // ai automation engineer
    </p>

    <h1 class="animate-hero mt-6 text-3xl font-bold tracking-tight text-gh-fg sm:text-4xl" style="animation-delay: 80ms;">
      AI automation for<br class="hidden sm:inline" /> business operations
    </h1>

    <p class="animate-hero mx-auto mt-6 max-w-xl text-sm leading-relaxed text-gh-fg-muted sm:text-base" style="animation-delay: 160ms;">
      Twenty years of hands-on engineering applied to ERP integration, document workflows, email, and reporting.
    </p>
  </section>

  <!-- What I build — four numbered tiles, mono everywhere -->
  <section class="mx-auto max-w-4xl px-6 pb-12 sm:pb-14 font-mono">
    <div class="grid gap-10 sm:grid-cols-2 sm:gap-x-12 sm:gap-y-14">

      <a href="/expertise#erp" class="animate-on-scroll group block" style="transition-delay: 0ms;">
        <div class="flex items-baseline gap-2 text-xs text-gh-fg-subtle">
          <span>01</span>
          <span class="h-px flex-1 bg-gh-border"></span>
        </div>
        <h3 class="mt-3 text-sm font-semibold text-gh-fg group-hover:text-gh-green transition-colors">
          ERP integration
        </h3>
        <p class="mt-2 text-xs leading-relaxed text-gh-fg-muted">
          ERP, accounting, CRM, and document stores connected so approvals, orders, and reporting run end-to-end without a person in the middle.
        </p>
      </a>

      <a href="/expertise#documents" class="animate-on-scroll group block" style="transition-delay: 80ms;">
        <div class="flex items-baseline gap-2 text-xs text-gh-fg-subtle">
          <span>02</span>
          <span class="h-px flex-1 bg-gh-border"></span>
        </div>
        <h3 class="mt-3 text-sm font-semibold text-gh-fg group-hover:text-gh-green transition-colors">
          document workflow
        </h3>
        <p class="mt-2 text-xs leading-relaxed text-gh-fg-muted">
          Structured extraction from invoices, contracts, and forms. Auto-routing to the system of record, with confidence scoring.
        </p>
      </a>

      <a href="/expertise#email" class="animate-on-scroll group block" style="transition-delay: 160ms;">
        <div class="flex items-baseline gap-2 text-xs text-gh-fg-subtle">
          <span>03</span>
          <span class="h-px flex-1 bg-gh-border"></span>
        </div>
        <h3 class="mt-3 text-sm font-semibold text-gh-fg group-hover:text-gh-green transition-colors">
          email &amp; communication
        </h3>
        <p class="mt-2 text-xs leading-relaxed text-gh-fg-muted">
          Triage, classification, and automated replies for inbound business email. LLM with retrieval over an internal knowledge base.
        </p>
      </a>

      <a href="/expertise#data" class="animate-on-scroll group block" style="transition-delay: 240ms;">
        <div class="flex items-baseline gap-2 text-xs text-gh-fg-subtle">
          <span>04</span>
          <span class="h-px flex-1 bg-gh-border"></span>
        </div>
        <h3 class="mt-3 text-sm font-semibold text-gh-fg group-hover:text-gh-green transition-colors">
          data &amp; reporting
        </h3>
        <p class="mt-2 text-xs leading-relaxed text-gh-fg-muted">
          Aggregate from databases, sheets, and APIs. LLM summaries with citations, delivered on schedule to email, Slack, or Drive.
        </p>
      </a>

    </div>
  </section>

  <!-- Why hire me — grid of credibility points -->
  <section class="mx-auto max-w-4xl px-6 pb-12 sm:pb-14">
    <p class="animate-on-scroll text-center text-sm font-bold uppercase tracking-[0.2em] text-gh-blue" style="transition-delay: 0ms;">
      // why hire me
    </p>

    <div class="mt-12 grid gap-10 sm:grid-cols-2 sm:gap-x-12 sm:gap-y-14">

      <div class="animate-on-scroll" style="transition-delay: 80ms;">
        <div class="flex items-baseline gap-2 text-xs text-gh-fg-subtle">
          <span>05</span>
          <span class="h-px flex-1 bg-gh-border"></span>
        </div>
        <h3 class="mt-3 text-sm font-semibold text-gh-fg">
          twenty years of production engineering
        </h3>
        <p class="mt-2 text-xs leading-relaxed text-gh-fg-muted">
          From data-center infrastructure to global payment systems to production AI agents. Built and shipped at every scale.
        </p>
      </div>

      <div class="animate-on-scroll" style="transition-delay: 160ms;">
        <div class="flex items-baseline gap-2 text-xs text-gh-fg-subtle">
          <span>06</span>
          <span class="h-px flex-1 bg-gh-border"></span>
        </div>
        <h3 class="mt-3 text-sm font-semibold text-gh-fg">
          full-stack AI, end-to-end
        </h3>
        <p class="mt-2 text-xs leading-relaxed text-gh-fg-muted">
          Architecture, backend, LLM layer, IaC, deployment. One engineer, the whole pipeline &mdash; no handoffs, no missing pieces.
        </p>
      </div>

      <div class="animate-on-scroll" style="transition-delay: 240ms;">
        <div class="flex items-baseline gap-2 text-xs text-gh-fg-subtle">
          <span>07</span>
          <span class="h-px flex-1 bg-gh-border"></span>
        </div>
        <h3 class="mt-3 text-sm font-semibold text-gh-fg">
          production over prototypes
        </h3>
        <p class="mt-2 text-xs leading-relaxed text-gh-fg-muted">
          Live agents handling real business email &mdash; not slide decks, not sandbox demos. The site you&rsquo;re reading is part of the proof.
        </p>
      </div>

      <div class="animate-on-scroll" style="transition-delay: 320ms;">
        <div class="flex items-baseline gap-2 text-xs text-gh-fg-subtle">
          <span>08</span>
          <span class="h-px flex-1 bg-gh-border"></span>
        </div>
        <h3 class="mt-3 text-sm font-semibold text-gh-fg">
          pattern-matching across domains
        </h3>
        <p class="mt-2 text-xs leading-relaxed text-gh-fg-muted">
          Payments, real estate, logistics, manufacturing. The bottlenecks repeat across industries; the fixes generalize.
        </p>
      </div>

    </div>
  </section>

  <!-- Proof of capability — MailPilot -->
  <section class="mx-auto max-w-4xl px-6 pb-20 sm:pb-24 text-center">
    <p class="animate-on-scroll text-sm font-bold uppercase tracking-[0.2em] text-gh-blue" style="transition-delay: 0ms;">
      // proof of capability
    </p>

    <p class="animate-on-scroll mx-auto mt-6 max-w-2xl text-sm leading-relaxed text-gh-fg-muted sm:text-base" style="transition-delay: 80ms;">
      MailPilot &mdash; a production AI agent that handles real business email end-to-end. Live at <span class="font-bold text-gh-fg">demo@lab5.ca</span>.
    </p>

    <div class="animate-on-scroll mt-8 flex flex-wrap justify-center gap-3" style="transition-delay: 160ms;">
      <a
        href="/demo"
        class="inline-flex items-center gap-2 rounded-lg border border-gh-border bg-white px-4 py-2 text-sm font-bold text-gh-fg transition-colors hover:bg-gh-canvas-subtle"
      >
        <svg class="h-4 w-4 text-gh-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
        </svg>
        MailPilot Demo
      </a>
      <a
        href="https://github.com/kborovik/mailpilot"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 rounded-lg border border-gh-border bg-white px-4 py-2 text-sm font-bold text-gh-fg transition-colors hover:bg-gh-canvas-subtle"
      >
        <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/></svg>
        github
      </a>
    </div>
  </section>
</Layout>
