---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <!-- Hero -->
  <section class="relative mx-auto max-w-5xl px-6 py-24 sm:py-32" style="background-image: radial-gradient(circle, rgba(31,136,61,0.04) 1px, transparent 1px), radial-gradient(ellipse at 50% 0%, rgba(31,136,61,0.03) 0%, transparent 60%); background-size: 40px 40px, 100% 100%;">
    <div class="flex flex-col items-center gap-12 lg:flex-row lg:items-center lg:gap-16">

      <!-- Left: copy -->
      <div class="flex-1 text-center lg:text-left">
        <div class="animate-hero mb-6 inline-flex items-center gap-2 rounded-full bg-gh-green-muted px-4 py-1.5 text-xs font-semibold uppercase tracking-widest text-gh-green" style="animation-delay: 0ms;">
          AI Automation Engineer
        </div>
        <h1 class="animate-hero font-serif text-4xl font-bold tracking-tight text-gh-fg sm:text-6xl" style="animation-delay: 80ms;">
          I modernize business operations with AI to make companies move faster
        </h1>
        <p class="animate-hero mx-auto mt-6 max-w-xl text-lg text-gh-fg-muted lg:mx-0" style="animation-delay: 160ms;">
          20+ years of hands-on engineering. I help companies automate repetitive work &mdash; email, documents, workflows, data entry &mdash; so the business moves faster.
        </p>
        <div class="animate-hero mt-10 flex flex-col items-center gap-4 sm:flex-row sm:justify-center lg:justify-start" style="animation-delay: 240ms;">
          <a
            href="https://www.linkedin.com/in/kborovik"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 rounded-lg bg-gh-blue px-6 py-3 text-base font-semibold text-white transition-colors hover:bg-gh-blue-hover"
          >
            <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.5 2h-17A1.5 1.5 0 002 3.5v17A1.5 1.5 0 003.5 22h17a1.5 1.5 0 001.5-1.5v-17A1.5 1.5 0 0020.5 2zM8 19H5v-9h3zM6.5 8.25A1.75 1.75 0 118.3 6.5a1.78 1.78 0 01-1.8 1.75zM19 19h-3v-4.74c0-1.42-.6-1.93-1.38-1.93A1.74 1.74 0 0013 14.19a.66.66 0 000 .14V19h-3v-9h2.9v1.3a3.11 3.11 0 012.7-1.4c1.55 0 3.36.86 3.36 3.66z" /></svg>
            LinkedIn
          </a>
          <a
            href="/demo"
            class="inline-flex items-center gap-2 rounded-lg bg-gh-green px-6 py-3 text-base font-semibold text-white transition-colors hover:bg-gh-green-hover"
          >
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" /></svg>
            See My Work
          </a>
        </div>
      </div>

      <!-- Right: what changes card (hidden on mobile) -->
      <div class="animate-hero-card hidden lg:block lg:w-[340px] xl:w-[380px]" style="animation-delay: 400ms;">
        <div class="rounded-2xl border border-gh-border bg-white shadow-sm overflow-hidden">
          <div class="border-b border-gh-border bg-gh-canvas-subtle px-4 py-3">
            <span class="text-xs font-semibold text-gh-fg-subtle uppercase tracking-wider">What Changes</span>
          </div>
          <div class="divide-y divide-gh-border">
            <div class="p-4 flex items-center gap-3">
              <div class="flex h-9 w-9 items-center justify-center rounded-lg bg-gh-green/10">
                <svg class="h-5 w-5 text-gh-green" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z" />
                </svg>
              </div>
              <div>
                <p class="text-sm font-semibold text-gh-fg">Manual work becomes automated</p>
                <p class="text-xs text-gh-fg-muted">AI handles repetitive tasks 24/7</p>
              </div>
            </div>
            <div class="p-4 flex items-center gap-3">
              <div class="flex h-9 w-9 items-center justify-center rounded-lg bg-gh-blue/10">
                <svg class="h-5 w-5 text-gh-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z" />
                </svg>
              </div>
              <div>
                <p class="text-sm font-semibold text-gh-fg">Email and documents process themselves</p>
                <p class="text-xs text-gh-fg-muted">Responses, summaries, filing &mdash; done</p>
              </div>
            </div>
            <div class="p-4 flex items-center gap-3">
              <div class="flex h-9 w-9 items-center justify-center rounded-lg bg-gh-green/10">
                <svg class="h-5 w-5 text-gh-green" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4" />
                </svg>
              </div>
              <div>
                <p class="text-sm font-semibold text-gh-fg">Disconnected tools get integrated</p>
                <p class="text-xs text-gh-fg-muted">ERP, email, documents — connected</p>
              </div>
            </div>
            <div class="p-4 flex items-center gap-3">
              <div class="flex h-9 w-9 items-center justify-center rounded-lg bg-gh-blue/10">
                <svg class="h-5 w-5 text-gh-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
              </div>
              <div>
                <p class="text-sm font-semibold text-gh-fg">Your company gets faster</p>
                <p class="text-xs text-gh-fg-muted">Same team, twice the output</p>
              </div>
            </div>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- How I Help -->
  <section class="border-t border-gh-border bg-gh-canvas-subtle py-24">
    <div class="mx-auto max-w-5xl px-6">
      <p class="animate-on-scroll text-sm font-semibold uppercase tracking-widest text-gh-green">How I Help</p>
      <h2 class="animate-on-scroll mt-2 font-serif text-3xl font-bold tracking-tight text-gh-fg sm:text-4xl">
        AI automation for every repetitive process
      </h2>
      <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">

        <!-- Card 1: Systems Integration -->
        <div class="card-accent group animate-on-scroll rounded-2xl border border-gh-border bg-white p-8 transition-all duration-200 hover:border-gh-green/30 hover:shadow-[0_4px_16px_rgba(0,0,0,0.06)]" style="transition-delay: 0ms;">
          <div class="mb-4 flex items-start gap-3">
            <div class="flex-shrink-0">
              <svg class="h-7 w-7 text-gh-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4" />
              </svg>
            </div>
            <div class="text-3xl font-light text-gh-border leading-none pt-0.5">01</div>
          </div>
          <h3 class="text-base font-semibold text-gh-fg">AI Email &amp; Communication</h3>
          <p class="mt-3 text-sm leading-relaxed text-gh-fg-muted">
            Automate email responses, triage, and customer communication &mdash; AI handles routine messages so your team focuses on what matters.
          </p>
          <a href="/expertise#email" class="link-animated mt-6 inline-flex items-center gap-1 text-sm font-semibold text-gh-green transition-colors hover:text-gh-green-hover">
            Learn more <span class="inline-block transition-transform duration-200 group-hover:translate-x-1">&rarr;</span>
          </a>
        </div>

        <!-- Card 2: Custom Software Development -->
        <div class="card-accent group animate-on-scroll rounded-2xl border border-gh-border bg-white p-8 transition-all duration-200 hover:border-gh-green/30 hover:shadow-[0_4px_16px_rgba(0,0,0,0.06)]" style="transition-delay: 60ms;">
          <div class="mb-4 flex items-start gap-3">
            <div class="flex-shrink-0">
              <svg class="h-7 w-7 text-gh-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
              </svg>
            </div>
            <div class="text-3xl font-light text-gh-border leading-none pt-0.5">02</div>
          </div>
          <h3 class="text-base font-semibold text-gh-fg">Document Processing</h3>
          <p class="mt-3 text-sm leading-relaxed text-gh-fg-muted">
            Extract data from invoices, contracts, and forms automatically &mdash; stop manual data entry and reduce errors.
          </p>
          <a href="/expertise#documents" class="link-animated mt-6 inline-flex items-center gap-1 text-sm font-semibold text-gh-green transition-colors hover:text-gh-green-hover">
            Learn more <span class="inline-block transition-transform duration-200 group-hover:translate-x-1">&rarr;</span>
          </a>
        </div>

        <!-- Card 3: AI-Powered Automation -->
        <div class="card-accent group animate-on-scroll rounded-2xl border border-gh-border bg-white p-8 transition-all duration-200 hover:border-gh-green/30 hover:shadow-[0_4px_16px_rgba(0,0,0,0.06)]" style="transition-delay: 120ms;">
          <div class="mb-4 flex items-start gap-3">
            <div class="flex-shrink-0">
              <svg class="h-7 w-7 text-gh-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z" />
              </svg>
            </div>
            <div class="text-3xl font-light text-gh-border leading-none pt-0.5">03</div>
          </div>
          <h3 class="text-base font-semibold text-gh-fg">Workflow Automation</h3>
          <p class="mt-3 text-sm leading-relaxed text-gh-fg-muted">
            Connect your business systems and automate repetitive processes &mdash; orders, approvals, reporting flow without human bottlenecks.
          </p>
          <a href="/expertise#workflows" class="link-animated mt-6 inline-flex items-center gap-1 text-sm font-semibold text-gh-green transition-colors hover:text-gh-green-hover">
            Learn more <span class="inline-block transition-transform duration-200 group-hover:translate-x-1">&rarr;</span>
          </a>
        </div>

        <!-- Card 4: Technical Leadership -->
        <div class="card-accent group animate-on-scroll rounded-2xl border border-gh-border bg-white p-8 transition-all duration-200 hover:border-gh-green/30 hover:shadow-[0_4px_16px_rgba(0,0,0,0.06)]" style="transition-delay: 180ms;">
          <div class="mb-4 flex items-start gap-3">
            <div class="flex-shrink-0">
              <svg class="h-7 w-7 text-gh-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <div class="text-3xl font-light text-gh-border leading-none pt-0.5">04</div>
          </div>
          <h3 class="text-base font-semibold text-gh-fg">Data &amp; Reporting</h3>
          <p class="mt-3 text-sm leading-relaxed text-gh-fg-muted">
            Turn scattered data into actionable reports &mdash; AI aggregates, summarizes, and surfaces what matters.
          </p>
          <a href="/expertise#data" class="link-animated mt-6 inline-flex items-center gap-1 text-sm font-semibold text-gh-green transition-colors hover:text-gh-green-hover">
            Learn more <span class="inline-block transition-transform duration-200 group-hover:translate-x-1">&rarr;</span>
          </a>
        </div>

      </div>
    </div>
  </section>

  <!-- Featured Project: MailPilot -->
  <section class="border-t border-gh-border bg-gh-canvas-subtle py-20">
    <div class="mx-auto max-w-5xl px-6">
      <p class="animate-on-scroll text-sm font-semibold uppercase tracking-widest text-gh-green">Featured Project</p>
      <h2 class="animate-on-scroll mt-2 font-serif text-3xl font-bold tracking-tight text-gh-fg sm:text-4xl">
        MailPilot &mdash; AI That Handles Real Business Email
      </h2>
      <p class="mt-3 max-w-2xl text-gh-fg-muted">
        A live AI agent that handles real business email &mdash; built to show how AI can work for your company.
      </p>

      <div class="mt-10 grid gap-8 lg:grid-cols-2">
        <!-- Left: technical details -->
        <div>
          <h3 class="text-base font-semibold text-gh-fg">Architecture & Stack</h3>
          <div class="mt-4 space-y-3">
            <div class="flex items-start gap-3">
              <svg class="mt-0.5 h-5 w-5 flex-shrink-0 text-gh-green" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <p class="text-sm text-gh-fg-muted"><span class="font-medium text-gh-fg">Backend:</span> Python, serverless functions, event-driven email processing</p>
            </div>
            <div class="flex items-start gap-3">
              <svg class="mt-0.5 h-5 w-5 flex-shrink-0 text-gh-green" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <p class="text-sm text-gh-fg-muted"><span class="font-medium text-gh-fg">AI Layer:</span> LLM integration, RAG pipeline, knowledge base search</p>
            </div>
            <div class="flex items-start gap-3">
              <svg class="mt-0.5 h-5 w-5 flex-shrink-0 text-gh-green" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <p class="text-sm text-gh-fg-muted"><span class="font-medium text-gh-fg">Frontend:</span> Astro, Tailwind CSS, edge deployment</p>
            </div>
            <div class="flex items-start gap-3">
              <svg class="mt-0.5 h-5 w-5 flex-shrink-0 text-gh-green" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <p class="text-sm text-gh-fg-muted"><span class="font-medium text-gh-fg">Infrastructure:</span> Terraform IaC, GitHub Actions CI/CD, cloud-native architecture</p>
            </div>
          </div>
          <a href="/demo" class="link-animated mt-6 inline-flex items-center gap-1 text-sm font-semibold text-gh-green transition-colors hover:text-gh-green-hover">
            See the live demo <span class="inline-block transition-transform duration-200 group-hover:translate-x-1">&rarr;</span>
          </a>
        </div>

        <!-- Right: live demo callout -->
        <div class="rounded-2xl border border-gh-border bg-white p-8">
          <h3 class="text-base font-semibold text-gh-fg">Try it yourself</h3>
          <p class="mt-2 text-sm text-gh-fg-muted">
            This is a live AI agent responding to real emails in real time.
            Send it a question and watch it work.
          </p>
          <div class="mt-6 inline-flex items-center gap-3 rounded-xl border border-gh-border bg-gh-canvas-subtle px-5 py-3 font-mono text-sm text-gh-fg">
            <svg class="h-4 w-4 text-gh-fg-subtle flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            <span>demo@lab5.ca</span>
            <button
              id="copy-email-btn"
              aria-label="Copy email address"
              class="flex items-center gap-1.5 rounded-md border border-gh-border bg-white px-2.5 py-1 text-xs font-semibold text-gh-fg-muted transition-colors hover:text-gh-fg cursor-pointer"
            >
              <svg id="copy-icon" class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
              </svg>
              <span id="copy-label">Copy</span>
            </button>
          </div>
          <div class="mt-4">
            <a
              href="mailto:demo@lab5.ca"
              class="inline-flex items-center gap-2 rounded-lg bg-gh-green px-5 py-2.5 text-sm font-semibold text-white transition-colors hover:bg-gh-green-hover"
            >
              Send an email →
            </a>
          </div>
          <p class="mt-3 text-xs text-gh-fg-subtle">Reply within 60 seconds. No signup required.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-24">
    <div class="animate-on-scroll mx-auto max-w-3xl px-6 text-center">
      <h2 class="font-serif text-3xl font-bold tracking-tight text-gh-fg sm:text-4xl">
        Ready to move faster?
      </h2>
      <p class="mx-auto mt-4 max-w-xl text-lg text-gh-fg-muted">
        I help companies automate repetitive work with AI. Let's talk.
      </p>
      <div class="mt-8 flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
        <a
          href="https://www.linkedin.com/in/kborovik"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-lg bg-gh-blue px-6 py-3 text-base font-semibold text-white transition-colors hover:bg-gh-blue-hover"
        >
          <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.5 2h-17A1.5 1.5 0 002 3.5v17A1.5 1.5 0 003.5 22h17a1.5 1.5 0 001.5-1.5v-17A1.5 1.5 0 0020.5 2zM8 19H5v-9h3zM6.5 8.25A1.75 1.75 0 118.3 6.5a1.78 1.78 0 01-1.8 1.75zM19 19h-3v-4.74c0-1.42-.6-1.93-1.38-1.93A1.74 1.74 0 0013 14.19a.66.66 0 000 .14V19h-3v-9h2.9v1.3a3.11 3.11 0 012.7-1.4c1.55 0 3.36.86 3.36 3.66z" /></svg>
          LinkedIn
        </a>
        <a
          href="https://calendar.app.google/cYM3H3TsHsequR587"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-lg bg-gh-green px-6 py-3 text-base font-semibold text-white transition-colors hover:bg-gh-green-hover"
        >
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor"><path d="M19 4h-1V2h-2v2H8V2H6v2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 16H5V10h14v10zm0-12H5V6h14v2zM7 12h5v5H7v-5z"/></svg>
          Book a Call
        </a>
      </div>
    </div>
  </section>

  <script>
    const btn = document.getElementById('copy-email-btn');
    const label = document.getElementById('copy-label');
    const icon = document.getElementById('copy-icon');

    btn?.addEventListener('click', () => {
      navigator.clipboard.writeText('demo@lab5.ca').then(() => {
        if (label) label.textContent = '✓ Copied';
        if (icon) icon.style.display = 'none';
        setTimeout(() => {
          if (label) label.textContent = 'Copy';
          if (icon) icon.style.display = '';
        }, 2000);
      });
    });
  </script>
</Layout>
