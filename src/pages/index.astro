---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import headshot from '../assets/konstantin-borovik-headshot.jpg';

const bookCallHref = 'https://calendar.app.google/cYM3H3TsHsequR587';
const costPostHref = '/blog/what-one-ai-email-costs';
const primaryCtaClass =
  'inline-flex items-center gap-2 rounded-lg bg-gh-green px-4 py-2 text-base font-semibold text-white transition-colors hover:bg-gh-green-hover';
const secondaryCtaClass =
  'inline-flex items-center gap-2 rounded-lg border border-gh-border bg-white px-4 py-2 text-base font-semibold text-gh-fg transition-colors hover:bg-gh-canvas-subtle';
const secondaryLinkClass =
  'text-gh-green underline underline-offset-[3px] hover:text-gh-green-hover transition-colors';

const moneyDiscipline = [
  { lead: 'Measure cost per outcome', body: 'per email, per document, per ticket — not token volume.' },
  { lead: 'Cap usage', body: 'so a bug can’t run up a fortune overnight.' },
  { lead: 'Instrument every call', body: 'so you can see exactly where the money goes.' },
  { lead: 'Ground answers in real sources', body: 'and decline when uncertain, so the system doesn’t invent facts under your brand.' },
  { lead: 'Scale to zero when idle', body: 'so you’re not paying for it overnight.' },
];

const trackRecord = [
  {
    lead: '20+ years shipping production software',
    body: 'data centers, payments, real estate. This isn’t my first system that has to work on Monday.',
  },
  {
    lead: 'Solo, end-to-end delivery',
    body: 'back-end, infrastructure, CI/CD, deployment, observability. One accountable owner, full product-cycle ownership.',
  },
  {
    lead: 'AI agents in production today',
    body: 'LLMs, retrieval (RAG), structured extraction, with the guardrails and tracing that make them safe to put in front of customers.',
  },
  {
    lead: 'Toronto-based, long-term contract',
    body: 'embedded with your team, not a drive-by engagement.',
  },
];

const costTable = [
  { metric: 'Cost per sourced reply', mailpilot: '~$0.03', person: '~$5.00' },
  { metric: 'Response time', mailpilot: '~20 seconds', person: 'hours' },
  { metric: 'Out-of-scope questions', mailpilot: 'declines, no guessing', person: 'varies' },
  { metric: 'At 1,000 emails / month', mailpilot: '~$30', person: '~$5,000' },
];
---

<Layout
  description="AI & LLM systems that do real work — measured cost per outcome, production agents traced to the dollar. Konstantin Borovik, Software Engineer in Toronto; 20+ years shipping software, AI agents in production today."
>
  <!-- (a) hero -->
  <section class="mx-auto max-w-5xl px-6 pt-16 pb-12 sm:pt-20 sm:pb-14 font-mono">
    <div class="grid gap-10 sm:grid-cols-3 sm:items-center">

      <div class="sm:col-span-2">
        <h1 class="animate-hero text-3xl font-bold tracking-tight text-gh-fg sm:text-4xl" style="animation-delay: 0ms;">
          LLM systems that do real work &mdash; without becoming a money pit.
        </h1>
        <p class="animate-hero mt-4 text-base leading-relaxed text-gh-fg-muted sm:text-lg" style="animation-delay: 80ms;">
          I build and optimize business processes with AI agents, then measure the cost per outcome so you can see the return before you scale it. Production systems, traced to the dollar &mdash; not pilots that quietly bleed.
        </p>

        <div class="animate-hero mt-6 flex flex-wrap items-center gap-x-5 gap-y-3" style="animation-delay: 160ms;">
          <a href={bookCallHref} target="_blank" rel="noopener noreferrer" class={primaryCtaClass}>
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor"><path d="M19 4h-1V2h-2v2H8V2H6v2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 16H5V10h14v10zm0-12H5V6h14v2zM7 12h5v5H7v-5z"/></svg>
            Book a 30-minute call
          </a>
          <a href={costPostHref} class={secondaryCtaClass}>
            See the cost-per-outcome math
          </a>
        </div>

        <p class="animate-hero mt-5 text-xs text-gh-fg-muted sm:text-sm" style="animation-delay: 240ms;">
          20+ years shipping production software &middot; AI agents running in production today &middot; Toronto-based
        </p>

        <div class="animate-hero mt-6 flex flex-wrap gap-3" style="animation-delay: 320ms;">
          <a
            href="https://www.linkedin.com/in/kborovik"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 rounded-lg border border-gh-border bg-white px-4 py-2 text-sm font-bold text-gh-fg transition-colors hover:bg-gh-canvas-subtle"
          >
            <svg class="h-4 w-4 text-gh-blue" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.063 2.063 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            linkedin
          </a>
          <a
            href="https://github.com/kborovik"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 rounded-lg border border-gh-border bg-white px-4 py-2 text-sm font-bold text-gh-fg transition-colors hover:bg-gh-canvas-subtle"
          >
            <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/></svg>
            github
          </a>
        </div>
      </div>

      <Image
        src={headshot}
        alt="Konstantin Borovik"
        width={400}
        height={400}
        class="animate-hero mx-auto h-40 w-40 rounded-lg border border-gh-border object-cover object-top sm:mx-0 sm:h-48 sm:w-48"
        style="animation-delay: 400ms;"
      />

    </div>
  </section>

  <!-- (b) the problem -->
  <section class="mx-auto max-w-5xl px-6 pb-12 sm:pb-14 font-mono">
    <h2 class="section-kicker animate-on-scroll text-base font-bold uppercase tracking-[0.2em] text-gh-blue" style="transition-delay: 0ms;">
      the problem
    </h2>
    <div class="animate-on-scroll mt-6 max-w-3xl space-y-4 text-base leading-relaxed text-gh-fg-muted" style="transition-delay: 80ms;">
      <p>
        Every business runs on a layer of repetitive, lookup-heavy work that quietly consumes skilled time. Answering the same product questions over and over. Pulling a number out of a document and writing it into a reply. Triaging inbound email. Filling the same fields from the same forms. None of it is hard &mdash; that&rsquo;s exactly why it&rsquo;s expensive. It&rsquo;s a knowledgeable person, on a loaded salary, spending hours a week on tasks that follow a pattern.
      </p>
      <p>
        The cost is hidden because it never shows up as a line item. It&rsquo;s spread across people who could be doing higher-value work, and across customers who wait hours for an answer that could take seconds.
      </p>
      <p>
        <span class="font-semibold text-gh-fg">Repetitive, lookup-heavy work is what LLM systems are genuinely good at</span> &mdash; high-volume, rule-following tasks, done instantly and consistently. The promise is simple: take that repetitive load off your team, answer it in seconds instead of hours, and free your skilled people for the work that actually needs a human.
      </p>
      <p>
        The catch is that it has to be built so you can trust it and afford it &mdash; grounded in real sources, designed to decline rather than guess, and measured to the dollar. To show what that looks like in practice, here&rsquo;s a real one I built and the math behind it.
      </p>
    </div>
  </section>

  <!-- (c) what I do — 2-offer block -->
  <section class="mx-auto max-w-5xl px-6 pb-12 sm:pb-14 font-mono">
    <h2 class="section-kicker animate-on-scroll text-base font-bold uppercase tracking-[0.2em] text-gh-blue" style="transition-delay: 0ms;">
      what I do
    </h2>

    <div class="mt-10 grid gap-10 sm:grid-cols-2 sm:gap-x-12">
      <div class="animate-on-scroll" style="transition-delay: 0ms;">
        <div class="flex items-baseline gap-2 text-xs text-gh-fg-muted">
          <span>01</span>
          <span class="h-px flex-1 bg-gh-border"></span>
        </div>
        <h3 class="mt-3 text-base font-semibold text-gh-fg">Build</h3>
        <p class="mt-3 text-sm leading-relaxed text-gh-fg-muted sm:text-base">
          A new business process, powered by an LLM agent and built to be measured from day one. High-volume, lookup-heavy, repetitive work &mdash; pre-sales questions, RFP responses, document processing, tier-one support &mdash; answered instantly and consistently, with the cost per outcome traced before you scale it.
        </p>
      </div>

      <div class="animate-on-scroll" style="transition-delay: 80ms;">
        <div class="flex items-baseline gap-2 text-xs text-gh-fg-muted">
          <span>02</span>
          <span class="h-px flex-1 bg-gh-border"></span>
        </div>
        <h3 class="mt-3 text-base font-semibold text-gh-fg">Optimize / Rescue</h3>
        <p class="mt-3 text-sm leading-relaxed text-gh-fg-muted sm:text-base">
          An AI initiative that&rsquo;s stalled or running up a bill nobody can explain. I instrument what it&rsquo;s actually doing, find where the money goes, cap the runaway paths, and add the grounding and guardrails that should have been there first &mdash; so it earns its keep instead of becoming the budget line you regret.
        </p>
      </div>
    </div>

    <p class="animate-on-scroll mt-10 max-w-3xl text-sm leading-relaxed text-gh-fg-muted sm:text-base" style="transition-delay: 160ms;">
      Either way you get one senior owner end to end: the retrieval, the guardrails, the observability, the deployment. No layer of account managers between you and the person building it.
    </p>
  </section>

  <!-- (d) proof — MailPilot evidence -->
  <section class="mx-auto max-w-5xl px-6 pb-12 sm:pb-14 font-mono">
    <h2 class="section-kicker animate-on-scroll text-base font-bold uppercase tracking-[0.2em] text-gh-blue" style="transition-delay: 0ms;">
      proof
    </h2>

    <div class="animate-on-scroll mt-6 max-w-3xl space-y-4 text-base leading-relaxed text-gh-fg-muted" style="transition-delay: 80ms;">
      <p>
        Fair thing to ask first: this is self-reported, it&rsquo;s one project, and the numbers are early. So here is what makes it checkable rather than something you take on my word &mdash; the code is open on GitHub, every model call is traced, and you can email the agent yourself and watch what it does. A claim you can verify beats a testimonial you can&rsquo;t.
      </p>
      <p>
        <span class="font-semibold text-gh-fg">I built MailPilot to solve a business problem of my own</span> (not a product I sell) &mdash; a production AI agent running on my company&rsquo;s inbox. It reads an incoming business email, searches a knowledge base, and replies with a sourced answer in under a minute. If the question is outside its knowledge base, it declines and says so rather than guessing.
      </p>
      <p>
        <a href="/mailpilot" class={secondaryLinkClass}>
          Here is the real proof &mdash; not just words, not empty promises &rarr;
        </a>
      </p>
      <p>Every model call is traced, so the economics aren&rsquo;t a guess:</p>
    </div>

    <div class="animate-on-scroll mt-6 overflow-x-auto" style="transition-delay: 160ms;">
      <table class="w-full max-w-3xl border border-gh-border text-sm">
        <thead class="bg-gh-canvas-subtle">
          <tr>
            <th class="px-4 py-3 text-left font-semibold text-gh-fg"></th>
            <th class="px-4 py-3 text-left font-semibold text-gh-fg">MailPilot (measured)</th>
            <th class="px-4 py-3 text-left font-semibold text-gh-fg">A person (assumption)</th>
          </tr>
        </thead>
        <tbody>
          {costTable.map((row, idx) => (
            <tr class={idx < costTable.length - 1 ? 'border-b border-gh-border' : ''}>
              <td class="px-4 py-3 font-semibold text-gh-fg">{row.metric}</td>
              <td class="px-4 py-3 text-gh-fg-muted">{row.mailpilot}</td>
              <td class="px-4 py-3 text-gh-fg-muted">{row.person}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <div class="animate-on-scroll mt-8 max-w-3xl space-y-4 text-base leading-relaxed text-gh-fg-muted" style="transition-delay: 240ms;">
      <p>
        More than a 100&times; difference in cost, hours-to-seconds in speed. The $5 is my assumption, labeled as one &mdash; swap in your own loaded cost per reply and the ratio shifts, but the order of magnitude doesn&rsquo;t. The point isn&rsquo;t to replace people &mdash; you can&rsquo;t fire 1/100th of an employee. It&rsquo;s that a category of repetitive work stops consuming thousands of dollars of skilled time and frees that person for work that needs them.
      </p>
      <p>
        <span class="font-semibold text-gh-fg">The cost is not the only risk &mdash; it&rsquo;s an agent confidently inventing a price or a spec and sending it over your name.</span> MailPilot grounds every answer in a source document and cites the file it used, so any reply is checkable. Out-of-scope detection and fabrication checks run as mechanical tests in every build cycle &mdash; behavior measured in the logs, not asserted in a slide.
      </p>
      <p>
        <a href={costPostHref} class={secondaryLinkClass}>
          Read the full cost-per-outcome breakdown &rarr;
        </a>
      </p>
    </div>
  </section>

  <!-- (f) how the money stays under control -->
  <section class="mx-auto max-w-5xl px-6 pb-12 sm:pb-14 font-mono">
    <h2 class="section-kicker animate-on-scroll text-base font-bold uppercase tracking-[0.2em] text-gh-blue" style="transition-delay: 0ms;">
      how the money stays under control
    </h2>
    <p class="animate-on-scroll mt-6 max-w-3xl text-base leading-relaxed text-gh-fg-muted" style="transition-delay: 80ms;">
      None of this is exotic &mdash; it&rsquo;s just the discipline most pilots skip:
    </p>
    <ul class="animate-on-scroll mt-6 max-w-3xl space-y-3 text-base leading-relaxed text-gh-fg-muted" style="transition-delay: 160ms;">
      {moneyDiscipline.map(item => (
        <li class="flex gap-3">
          <span class="text-gh-fg-muted">&minus;</span>
          <span><span class="font-semibold text-gh-fg">{item.lead}</span> &mdash; {item.body}</span>
        </li>
      ))}
    </ul>
    <p class="animate-on-scroll mt-8 max-w-3xl text-base leading-relaxed text-gh-fg-muted" style="transition-delay: 240ms;">
      That&rsquo;s the difference between the 5% and the 95%, and it&rsquo;s mostly a question of how the system is built &mdash; not which model it uses.
    </p>
  </section>

  <!-- (g) why me — wholesale-vs-retail + track record -->
  <section class="mx-auto max-w-5xl px-6 pb-12 sm:pb-14 font-mono">
    <h2 class="section-kicker animate-on-scroll text-base font-bold uppercase tracking-[0.2em] text-gh-blue" style="transition-delay: 0ms;">
      why me
    </h2>

    <div class="animate-on-scroll mt-6 max-w-3xl space-y-4 text-base leading-relaxed text-gh-fg-muted" style="transition-delay: 80ms;">
      <p>
        <span class="font-semibold text-gh-fg">You pay wholesale, not retail.</span>
      </p>
      <p>
        When you hire a software agency, most of your bill never reaches the people writing your software. It pays for the sales team that closed the deal, the account manager who forwards your emails, the project manager who runs the standups, and the margin stacked on top of all of it. The engineer doing the actual work often sees only a fraction of the rate you&rsquo;re billed. Put the other way: the rate an agency charges is frequently three to four times what reaches the person who writes your code.
      </p>
      <p>
        Working with me, that overhead doesn&rsquo;t exist. No sales layer, no management tier, no markup on a subcontractor. You pay the person building the system directly &mdash; and you get that senior person on every call, not a junior assigned after the pitch.
      </p>
      <p>
        It&rsquo;s also why the strongest engineers don&rsquo;t stay at agencies: the model keeps most of what they earn. Going direct gets you both the more senior person and the lower rate at once &mdash; the two things an agency&rsquo;s structure is built to keep apart.
      </p>
    </div>

    <div class="animate-on-scroll mt-6 max-w-3xl space-y-4 text-base leading-relaxed text-gh-fg-muted" style="transition-delay: 120ms;">
      <p>
        The quieter worry with one person: what if I get hit by a bus? Worth saying plainly &mdash; every employee is a bus-factor too, and usually a worse one, because the knowledge that walks out with them was never written down.
      </p>
      <p>
        You don&rsquo;t carry that exposure here. You hold the whole system: the code lives in your repository, it runs in your cloud account, and the retrieval, guardrails, and observability come documented in plain language &mdash; not locked in my head. Any competent engineer can pick it up and keep going, which makes the bus-factor lower than most hires give you. It&rsquo;s the inverse of the lock-in an agency sells: handover is a git clone, not a renegotiation.
      </p>
      <p>
        The honest boundary: if the work genuinely needs a full standing team, that&rsquo;s work for a team &mdash; not what I&rsquo;m pitching here.
      </p>
    </div>

    <p class="animate-on-scroll mt-10 max-w-3xl text-base text-gh-fg-muted" style="transition-delay: 160ms;">
      The credentials behind that:
    </p>
    <ul class="animate-on-scroll mt-4 max-w-3xl space-y-3 text-base leading-relaxed text-gh-fg-muted" style="transition-delay: 240ms;">
      {trackRecord.map(item => (
        <li class="flex gap-3">
          <span class="text-gh-fg-muted">&minus;</span>
          <span><span class="font-semibold text-gh-fg">{item.lead}</span> &mdash; {item.body}</span>
        </li>
      ))}
    </ul>

    <p class="animate-on-scroll mt-8 max-w-3xl text-sm leading-relaxed text-gh-fg-muted" style="transition-delay: 320ms;">
      Built on: Anthropic Claude &middot; Google Gemini &middot; Python &middot; FastAPI &middot; Pydantic AI &middot; RAG &middot; MCP &middot; Google Cloud / Azure &middot; Terraform &middot; Kubernetes &middot; OpenTelemetry
    </p>
  </section>

  <!-- (h) closing CTA -->
  <section class="mx-auto max-w-5xl px-6 pb-16 sm:pb-20 font-mono">
    <h2 class="section-kicker animate-on-scroll text-base font-bold uppercase tracking-[0.2em] text-gh-blue" style="transition-delay: 0ms;">
      closing
    </h2>
    <div class="animate-on-scroll mt-6 max-w-3xl space-y-4 text-base leading-relaxed text-gh-fg-muted" style="transition-delay: 80ms;">
      <p>
        If you&rsquo;re evaluating whether AI can do real work in your business without becoming a money pit &mdash; that&rsquo;s precisely the question I build for, and measure.
      </p>
      <p>Want the cost-per-outcome math on a workflow in your own operation?</p>
    </div>
    <div class="animate-on-scroll mt-6" style="transition-delay: 160ms;">
      <a href={bookCallHref} target="_blank" rel="noopener noreferrer" class={primaryCtaClass}>
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor"><path d="M19 4h-1V2h-2v2H8V2H6v2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 16H5V10h14v10zm0-12H5V6h14v2zM7 12h5v5H7v-5z"/></svg>
        Book a 30-minute call
      </a>
    </div>
  </section>

</Layout>
